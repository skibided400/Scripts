function Library:CreateDropdown(window, text, options, default, callback, flag)
    local Dropdown = {
        Type = "Dropdown",
        Options = options or {},
        Value = default or (options and options[1]) or "",
        Flag = flag or text .. "_Dropdown",
        Callback = callback,
        Open = false,
        Window = window,
    }

    local DropdownFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
        ClipsDescendants = true,
    })
    CreateCorner(DropdownFrame)

    local DropdownButton = CreateInstance("TextButton", {
        Name = "Button",
        Parent = DropdownFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
        Font = Config.Theme.Font,
        Text = text .. ": " .. tostring(Dropdown.Value),
        TextColor3 = Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    CreatePadding(DropdownButton, 6)

    local Arrow = CreateInstance("TextLabel", {
        Name = "Arrow",
        Parent = DropdownButton,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 16, 1, 0),
        Position = UDim2.new(1, -16, 0, 0),
        Font = Config.Theme.Font,
        Text = "▼",
        TextColor3 = Config.Theme.Text,
        TextSize = 10,
    })

    local OptionsContainer = CreateInstance("Frame", {
        Name = "Options",
        Parent = DropdownFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, Config.Theme.ElementHeight),
    })
    CreatePadding(OptionsContainer, 2)
    local OptionsLayout = CreateListLayout(OptionsContainer, 1)

    local function BuildOptions()
        for _, child in pairs(OptionsContainer:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        for _, option in pairs(Dropdown.Options) do
            local OptionBtn = CreateInstance("TextButton", {
                Name = option,
                Parent = OptionsContainer,
                BackgroundColor3 = Config.Theme.TitleBar,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 20),
                Font = Config.Theme.Font,
                Text = tostring(option),
                TextColor3 = option == Dropdown.Value and Config.Theme.Accent or Config.Theme.Text,
                TextSize = 11,
            })
            CreateCorner(OptionBtn)

            OptionBtn.MouseButton1Click:Connect(function()
                Dropdown.Value = option
                DropdownButton.Text = text .. ": " .. tostring(option)
                Dropdown.Open = false
                DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight)
                Arrow.Text = "▼"

                if callback then
                    task.spawn(function()
                        local success, err = pcall(callback, option)
                        if not success then
                            warn("Dropdown callback error: " .. tostring(err))
                        end
                    end)
                end

                if Config.AutoSave then
                    self:SaveConfig()
                end
            end)

            OptionBtn.MouseEnter:Connect(function()
                OptionBtn.BackgroundColor3 = Config.Theme.ElementHover
            end)
            OptionBtn.MouseLeave:Connect(function()
                OptionBtn.BackgroundColor3 = Config.Theme.TitleBar
            end)
        end
    end

    BuildOptions()

    DropdownButton.MouseButton1Click:Connect(function()
        Dropdown.Open = not Dropdown.Open
        if Dropdown.Open then
            local optionsHeight = math.min(#Dropdown.Options * 21, 150)
            DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight + optionsHeight)
            Arrow.Text = "▲"
        else
            DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight)
            Arrow.Text = "▼"
        end
    end)

    Dropdown.Set = function(value)
        Dropdown.Value = value
        DropdownButton.Text = text .. ": " .. tostring(value)
        if callback then
            task.spawn(function()
                pcall(callback, value)
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    Dropdown.AddOption = function(option)
        table.insert(Dropdown.Options, option)
        BuildOptions()
    end

    Dropdown.RemoveOption = function(option)
        for i, opt in pairs(Dropdown.Options) do
            if opt == option then
                table.remove(Dropdown.Options, i)
                break
            end
        end
        BuildOptions()
    end

    Dropdown.Frame = DropdownFrame
    Elements[Dropdown.Flag] = Dropdown
    table.insert(window.Elements, Dropdown)

    ApplyPendingElementConfig(self, Dropdown, "Dropdown")

    return Dropdown
end

