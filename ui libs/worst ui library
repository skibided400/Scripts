-- MultiDropdown Element (select multiple options)
function Library:CreateMultiDropdown(window, text, options, default, callback, flag)
    local MultiDropdown = {
        Type = "MultiDropdown",
        Options = options or {},
        Value = default or {},
        Flag = flag or text .. "_MultiDropdown",
        Callback = callback,
        Open = false,
        Window = window,
    }

    local DropdownFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
        ClipsDescendants = true,
    })
    CreateCorner(DropdownFrame)

    local DropdownButton = CreateInstance("TextButton", {
        Name = "Button",
        Parent = DropdownFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
        Font = Config.Theme.Font,
        Text = text .. ": [" .. #MultiDropdown.Value .. "]",
        TextColor3 = Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    CreatePadding(DropdownButton, 6)

    local Arrow = CreateInstance("TextLabel", {
        Name = "Arrow",
        Parent = DropdownButton,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 16, 1, 0),
        Position = UDim2.new(1, -16, 0, 0),
        Font = Config.Theme.Font,
        Text = "▼",
        TextColor3 = Config.Theme.Text,
        TextSize = 10,
    })

    local OptionsContainer = CreateInstance("Frame", {
        Name = "Options",
        Parent = DropdownFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, Config.Theme.ElementHeight),
    })
    CreatePadding(OptionsContainer, 2)
    local OptionsLayout = CreateListLayout(OptionsContainer, 1)

    local function IsSelected(option)
        for _, sel in pairs(MultiDropdown.Value) do
            if sel == option then return true end
        end
        return false
    end

    local function BuildOptions()
        for _, child in pairs(OptionsContainer:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        for _, option in pairs(MultiDropdown.Options) do
            local OptionBtn = CreateInstance("TextButton", {
                Name = option,
                Parent = OptionsContainer,
                BackgroundColor3 = Config.Theme.TitleBar,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 20),
                Font = Config.Theme.Font,
                Text = (IsSelected(option) and "☑ " or "☐ ") .. tostring(option),
                TextColor3 = IsSelected(option) and Config.Theme.Accent or Config.Theme.Text,
                TextSize = 11,
            })
            CreateCorner(OptionBtn)

            OptionBtn.MouseButton1Click:Connect(function()
                local selected = IsSelected(option)
                if selected then
                    for i, sel in pairs(MultiDropdown.Value) do
                        if sel == option then
                            table.remove(MultiDropdown.Value, i)
                            break
                        end
                    end
                else
                    table.insert(MultiDropdown.Value, option)
                end
                DropdownButton.Text = text .. ": [" .. #MultiDropdown.Value .. "]"
                OptionBtn.Text = (IsSelected(option) and "☑ " or "☐ ") .. tostring(option)
                OptionBtn.TextColor3 = IsSelected(option) and Config.Theme.Accent or Config.Theme.Text

                if callback then
                    task.spawn(function()
                        local success, err = pcall(callback, MultiDropdown.Value)
                        if not success then
                            warn("MultiDropdown callback error: " .. tostring(err))
                        end
                    end)
                end
                if Config.AutoSave then
                    self:SaveConfig()
                end
            end)

            OptionBtn.MouseEnter:Connect(function()
                OptionBtn.BackgroundColor3 = Config.Theme.ElementHover
            end)
            OptionBtn.MouseLeave:Connect(function()
                OptionBtn.BackgroundColor3 = Config.Theme.TitleBar
            end)
        end
    end

    BuildOptions()

    DropdownButton.MouseButton1Click:Connect(function()
        MultiDropdown.Open = not MultiDropdown.Open
        if MultiDropdown.Open then
            local optionsHeight = math.min(#MultiDropdown.Options * 21, 150)
            DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight + optionsHeight)
            Arrow.Text = "▲"
        else
            DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight)
            Arrow.Text = "▼"
        end
    end)

    local function SetValue(values)
        MultiDropdown.Value = values or {}
        DropdownButton.Text = text .. ": [" .. #MultiDropdown.Value .. "]"
        BuildOptions()
        if callback then
            task.spawn(function()
                pcall(callback, MultiDropdown.Value)
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    MultiDropdown.Set = SetValue
    MultiDropdown.Frame = DropdownFrame
    Elements[MultiDropdown.Flag] = MultiDropdown
    table.insert(window.Elements, MultiDropdown)

    ApplyPendingElementConfig(self, MultiDropdown, "MultiDropdown")

    return MultiDropdown
end

