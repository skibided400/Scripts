        local color = Color3.fromHSV(hue, sat, val)
        ColorPicker.Value = color
        ColorPreview.BackgroundColor3 = color
        HSPicker.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)

        RBox.Text = tostring(math.floor(color.R * 255))
        GBox.Text = tostring(math.floor(color.G * 255))
        BBox.Text = tostring(math.floor(color.B * 255))
        HexBox.Text = string.format("#%02X%02X%02X", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255))

        if callback then
            task.spawn(function()
                local success, err = pcall(callback, color)
                if not success then
                    warn("ColorPicker callback error: " .. tostring(err))
                end
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    local function SetColor(color)
        ColorPicker.Value = color
        hue, sat, val = color:ToHSV()

        HSCursor.Position = UDim2.new(sat, -3, 1 - val, -3)
        HueCursor.Position = UDim2.new(hue, 0, 0, 0)

        UpdateColorFromHSV()
    end

    -- Unified input handler for HS picker (mouse + touch)
    local function HandleHSInput(input)
        local absPos = HSPicker.AbsolutePosition
        local absSize = HSPicker.AbsoluteSize
        local relX = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
        local relY = math.clamp((input.Position.Y - absPos.Y) / absSize.Y, 0, 1)
        sat = relX
        val = 1 - relY
        HSCursor.Position = UDim2.new(sat, -3, 1 - val, -3)
        UpdateColorFromHSV()
    end

    local hsDragging = false
    HSPicker.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            hsDragging = true
            HandleHSInput(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if hsDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            HandleHSInput(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            hsDragging = false
        end
    end)

    -- Unified input handler for Hue slider (mouse + touch)
    local function HandleHueInput(input)
        local absPos = HueSlider.AbsolutePosition
        local absSize = HueSlider.AbsoluteSize
        hue = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
