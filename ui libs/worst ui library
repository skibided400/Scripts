        Size = UDim2.new(1, 0, 1, 0),
        Image = imageId,
        ScaleType = Enum.ScaleType.Fit,
    })
    CreateCorner(Image)
    CreateStroke(Image)

    if tooltipText then
        Image.MouseEnter:Connect(function()
            self:ShowTooltip(Image, tooltipText)
        end)
