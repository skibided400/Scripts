    SetColor(ColorPicker.Value)

    ColorPicker.Set = SetColor
    ColorPicker.Frame = PickerFrame
    Elements[ColorPicker.Flag] = ColorPicker
    table.insert(window.Elements, ColorPicker)

    ApplyPendingElementConfig(self, ColorPicker, "ColorPicker")

    return ColorPicker
end

