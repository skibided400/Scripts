    })

    local MinusBtn = CreateInstance("TextButton", {
        Name = "Minus",
        Parent = InputContainer,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(0.5, -52, 0, 0), -- CENTERED: half width minus half total input width
        Font = Config.Theme.Font,
        Text = "-",
        TextColor3 = Config.Theme.Text,
        TextSize = 14,
    })
    CreateCorner(MinusBtn)

    local InputBox = CreateInstance("TextBox", {
        Name = "Input",
        Parent = InputContainer,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 60, 1, 0), -- FIXED WIDTH for proper centering
        Position = UDim2.new(0.5, -30, 0, 0), -- CENTERED HORIZONTALLY
        Font = Config.Theme.Font,
        Text = tostring(NumberBox.Value),
        TextColor3 = Config.Theme.Text,
        TextSize = 11,
        ClearTextOnFocus = false,
        TextXAlignment = Enum.TextXAlignment.Center, -- CENTER NUMBER TEXT
    })
    CreateCorner(InputBox)

    local PlusBtn = CreateInstance("TextButton", {
        Name = "Plus",
        Parent = InputContainer,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(0.5, 32, 0, 0), -- CENTERED: positioned after input box
        Font = Config.Theme.Font,
        Text = "+",
        TextColor3 = Config.Theme.Text,
        TextSize = 14,
    })
    CreateCorner(PlusBtn)

    local function SetValue(value)
        value = math.clamp(value, NumberBox.Min, NumberBox.Max)
        if NumberBox.Step >= 1 then
            value = math.floor(value / NumberBox.Step) * NumberBox.Step
        else
            value = math.floor(value * (1 / NumberBox.Step)) / (1 / NumberBox.Step)
        end
        NumberBox.Value = value
        InputBox.Text = tostring(value)

        if callback then
            task.spawn(function()
                local success, err = pcall(callback, value)
                if not success then
                    warn("NumberBox callback error: " .. tostring(err))
                end
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    MinusBtn.MouseButton1Click:Connect(function()
        SetValue(NumberBox.Value - NumberBox.Step)
    end)

    PlusBtn.MouseButton1Click:Connect(function()
        SetValue(NumberBox.Value + NumberBox.Step)
    end)

    InputBox.FocusLost:Connect(function()
        local num = tonumber(InputBox.Text)
        if num then
            SetValue(num)
        else
            InputBox.Text = tostring(NumberBox.Value)
        end
    end)

    NumberBox.Set = SetValue
    NumberBox.Frame = BoxFrame
    Elements[NumberBox.Flag] = NumberBox
    table.insert(window.Elements, NumberBox)

    ApplyPendingElementConfig(self, NumberBox, "NumberBox")

    return NumberBox
end

