-- Utility Functions
local function MakeDraggable(obj, dragHandle)
    dragHandle = dragHandle or obj
    local dragging = false
    local dragStart = nil
    local startPos = nil

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local function CreateInstance(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        instance[prop] = value
    end
    return instance
end

local function CreateCorner(parent, radius)
    local corner = CreateInstance("UICorner", {
        Parent = parent,
        CornerRadius = radius or Config.Theme.CornerRadius,
    })
    return corner
end

local function CreateStroke(parent, color, thickness)
    local stroke = CreateInstance("UIStroke", {
        Parent = parent,
        Color = color or Config.Theme.Border,
        Thickness = thickness or 1,
    })
    return stroke
end

local function CreatePadding(parent, padding)
    local pad = CreateInstance("UIPadding", {
        Parent = parent,
        PaddingLeft = UDim.new(0, padding or Config.Theme.Padding),
        PaddingRight = UDim.new(0, padding or Config.Theme.Padding),
        PaddingTop = UDim.new(0, padding or Config.Theme.Padding),
        PaddingBottom = UDim.new(0, padding or Config.Theme.Padding),
    })
    return pad
end

local function CreateListLayout(parent, padding)
    local layout = CreateInstance("UIListLayout", {
        Parent = parent,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, padding or 2),
    })
    return layout
end

-- Helper: apply a single element's pending config value when it's created
local function ApplyPendingElementConfig(self, element, elementType)
    if self.PendingConfig and self.PendingConfig.Elements then
        local data = self.PendingConfig.Elements[element.Flag]
        if data and data.Type == elementType then
            if element.Set then
                if elementType == "ColorPicker" then
                    element.Set(Color3.new(data.Value[1], data.Value[2], data.Value[3]))
                elseif elementType == "Keybind" then
                    local keyCode = Enum.KeyCode[data.Value]
                    if keyCode then
                        element.Set(keyCode)
                    end
                elseif elementType == "MultiDropdown" then
                    element.Set(data.Value)
                else
                    element.Set(data.Value)
                end
            end
            self.PendingConfig.Elements[element.Flag] = nil
        end
    end
end

-- Initialize UI
function Library:Init()
    if ScreenGui then return end

    ScreenGui = CreateInstance("ScreenGui", {
        Name = "WurstUI",
        Parent = CoreGui,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
    })
    Library.ScreenGui = ScreenGui

    MainFrame = CreateInstance("Frame", {
        Name = "Main",
        Parent = ScreenGui,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
    })
    Library.MainFrame = MainFrame

    -- Load saved config
    self:LoadConfig()
    self:ApplyConfig()

    -- Auto-save loop
    if Config.AutoSave then
        task.spawn(function()
            while ScreenGui and ScreenGui.Parent do
                task.wait(Config.SaveInterval)
                if ScreenGui and ScreenGui.Parent then
                    self:SaveConfig()
                end
            end
        end)
    end

    -- Save on player leaving
    game.Players.LocalPlayer.CharacterRemoving:Connect(function()
        self:SaveConfig()
    end)
end

-- Live Theme Updater: refreshes all existing UI when theme values change
function Library:UpdateElementTheme(element)
    if not element or not element.Frame then return end
    if not element.Type then return end

    local frame = element.Frame

    if element.Type == "Toggle" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local button = frame:FindFirstChild("Button")
        if button then
            button.Font = Config.Theme.Font
            button.TextSize = Config.Theme.TextSize
            button.TextColor3 = element.Value and Config.Theme.ToggleOn or Config.Theme.Text
        end
        local indicator = frame:FindFirstChild("Indicator")
        if indicator then
            indicator.BackgroundColor3 = element.Value and Config.Theme.ToggleOn or Config.Theme.ToggleOff
        end

    elseif element.Type == "Button" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local button = frame:FindFirstChild("Button")
        if button then
            button.Font = Config.Theme.Font
            button.TextSize = Config.Theme.TextSize
            button.TextColor3 = Config.Theme.Text
        end

    elseif element.Type == "TextBox" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local label = frame:FindFirstChild("Label")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = 11
            label.TextColor3 = Config.Theme.Text
        end
        local input = frame:FindFirstChild("Input")
        if input then
            input.BackgroundColor3 = Config.Theme.TitleBar
            input.Font = Config.Theme.Font
            input.TextSize = 11
            input.TextColor3 = Config.Theme.Text
        end

    elseif element.Type == "Dropdown" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local button = frame:FindFirstChild("Button")
        if button then
            button.Font = Config.Theme.Font
            button.TextSize = Config.Theme.TextSize
            button.TextColor3 = Config.Theme.Text
        end
        local arrow = frame:FindFirstChild("Arrow")
        if arrow then
            arrow.TextColor3 = Config.Theme.Text
        end
        local options = frame:FindFirstChild("Options")
        if options then
            for _, child in pairs(options:GetChildren()) do
                if child:IsA("TextButton") then
                    child.BackgroundColor3 = Config.Theme.TitleBar
                    child.Font = Config.Theme.Font
                    child.TextSize = 11
                    child.TextColor3 = (child.Name == tostring(element.Value)) and Config.Theme.Accent or Config.Theme.Text
                end
            end
        end

    elseif element.Type == "Slider" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local label = frame:FindFirstChild("Label")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = 11
            label.TextColor3 = Config.Theme.Text
        end
        local valueLabel = frame:FindFirstChild("Value")
        if valueLabel then
            valueLabel.Font = Config.Theme.Font
            valueLabel.TextSize = 11
            valueLabel.TextColor3 = Config.Theme.Accent
        end
        local bar = frame:FindFirstChild("Bar")
        if bar then
            bar.BackgroundColor3 = Config.Theme.TitleBar
            local fill = bar:FindFirstChild("Fill")
            if fill then
                fill.BackgroundColor3 = Config.Theme.Accent
            end
            local knob = bar:FindFirstChild("Knob")
            if knob then
                knob.BackgroundColor3 = Config.Theme.Text
            end
        end

    elseif element.Type == "ColorPicker" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local button = frame:FindFirstChild("Button")
        if button then
            button.Font = Config.Theme.Font
            button.TextSize = Config.Theme.TextSize
            button.TextColor3 = Config.Theme.Text
            local preview = button:FindFirstChild("Preview")
            if preview then
                local stroke = preview:FindFirstChildOfClass("UIStroke")
                if stroke then
                    stroke.Color = Config.Theme.Border
                end
            end
        end
        local popup = frame:FindFirstChild("Popup")
        if popup then
            popup.BackgroundColor3 = Config.Theme.TitleBar
            local hs = popup:FindFirstChild("HS")
            if hs then
                local cursor = hs:FindFirstChild("Cursor")
                if cursor then
                    cursor.BackgroundColor3 = Config.Theme.Text
                    local stroke = cursor:FindFirstChildOfClass("UIStroke")
                    if stroke then
                        stroke.Color = Color3.fromRGB(0, 0, 0)
                    end
                end
            end
            local hue = popup:FindFirstChild("Hue")
            if hue then
                local cursor = hue:FindFirstChild("Cursor")
                if cursor then
                    cursor.BackgroundColor3 = Config.Theme.Text
                    local stroke = cursor:FindFirstChildOfClass("UIStroke")
                    if stroke then
                        stroke.Color = Color3.fromRGB(0, 0, 0)
                    end
                end
            end
            local rgb = popup:FindFirstChild("RGB")
            if rgb then
                for _, box in pairs(rgb:GetChildren()) do
                    if box:IsA("TextBox") then
                        box.BackgroundColor3 = Config.Theme.ElementBackground
                        box.Font = Config.Theme.Font
                        box.TextSize = 11
                    end
                end
            end
            local hex = popup:FindFirstChild("Hex")
            if hex then
                hex.BackgroundColor3 = Config.Theme.ElementBackground
                hex.Font = Config.Theme.Font
                hex.TextSize = 11
                hex.TextColor3 = Config.Theme.Text
            end
        end

    elseif element.Type == "Keybind" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local label = frame:FindFirstChild("Label")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = Config.Theme.TextSize
            label.TextColor3 = Config.Theme.Text
        end
        local key = frame:FindFirstChild("Key")
        if key then
            key.BackgroundColor3 = Config.Theme.TitleBar
            key.Font = Config.Theme.Font
            key.TextSize = 10
            key.TextColor3 = Config.Theme.Text
        end

    elseif element.Type == "Paragraph" then
        local label = frame:FindFirstChild("Text")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = Config.Theme.TextSize
            label.TextColor3 = Config.Theme.Text
        end

    elseif element.Type == "Separator" then
        local line = frame:FindFirstChild("Line")
        if line then
            line.BackgroundColor3 = Config.Theme.Border
        end
        local label = frame:FindFirstChild("Label")
        if label then
            label.BackgroundColor3 = Config.Theme.ElementBackground
            label.Font = Config.Theme.Font
            label.TextSize = 10
            label.TextColor3 = Config.Theme.TextDisabled
        end

    elseif element.Type == "Label" then
        local label = frame:FindFirstChild("Text")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = Config.Theme.TextSize
            label.TextColor3 = element.Color or Config.Theme.Text
        end

    elseif element.Type == "MultiDropdown" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local button = frame:FindFirstChild("Button")
        if button then
            button.Font = Config.Theme.Font
            button.TextSize = Config.Theme.TextSize
            button.TextColor3 = Config.Theme.Text
        end
        local arrow = frame:FindFirstChild("Arrow")
        if arrow then
            arrow.TextColor3 = Config.Theme.Text
        end
        local options = frame:FindFirstChild("Options")
        if options then
            for _, child in pairs(options:GetChildren()) do
                if child:IsA("TextButton") then
                    child.BackgroundColor3 = Config.Theme.TitleBar
                    child.Font = Config.Theme.Font
                    child.TextSize = 11
                    local isSelected = false
                    for _, sel in pairs(element.Value or {}) do
                        if tostring(sel) == child.Name then
                            isSelected = true
                            break
                        end
                    end
                    child.TextColor3 = isSelected and Config.Theme.Accent or Config.Theme.Text
                end
            end
        end

    elseif element.Type == "NumberBox" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local label = frame:FindFirstChild("Label")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = 11
            label.TextColor3 = Config.Theme.Text
        end
        local input = frame:FindFirstChild("Input")
        if input then
            input.BackgroundColor3 = Config.Theme.TitleBar
            input.Font = Config.Theme.Font
            input.TextSize = 11
            input.TextColor3 = Config.Theme.Text
        end
        local minus = frame:FindFirstChild("Minus")
        local plus = frame:FindFirstChild("Plus")
        if minus then
            minus.BackgroundColor3 = Config.Theme.TitleBar
            minus.TextColor3 = Config.Theme.Text
        end
        if plus then
            plus.BackgroundColor3 = Config.Theme.TitleBar
            plus.TextColor3 = Config.Theme.Text
        end

    elseif element.Type == "ProgressBar" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local label = frame:FindFirstChild("Label")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = 11
            label.TextColor3 = Config.Theme.Text
        end
        local bar = frame:FindFirstChild("Bar")
        if bar then
            bar.BackgroundColor3 = Config.Theme.TitleBar
            local fill = bar:FindFirstChild("Fill")
            if fill then
                fill.BackgroundColor3 = Config.Theme.Accent
            end
        end
        local valueLabel = frame:FindFirstChild("Value")
        if valueLabel then
            valueLabel.Font = Config.Theme.Font
            valueLabel.TextSize = 11
            valueLabel.TextColor3 = Config.Theme.Accent
        end

    elseif element.Type == "RadioButtonSet" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local label = frame:FindFirstChild("Label")
        if label then
            label.Font = Config.Theme.Font
            label.TextSize = 11
            label.TextColor3 = Config.Theme.Text
        end
        local options = frame:FindFirstChild("Options")
        if options then
            for _, child in pairs(options:GetChildren()) do
                if child:IsA("TextButton") then
                    child.BackgroundColor3 = Config.Theme.TitleBar
                    child.Font = Config.Theme.Font
                    child.TextSize = 11
                    child.TextColor3 = (child.Name == tostring(element.Value)) and Config.Theme.Accent or Config.Theme.Text
                    local dot = child:FindFirstChild("Dot")
                    if dot then
                        dot.BackgroundColor3 = (child.Name == tostring(element.Value)) and Config.Theme.Accent or Config.Theme.ToggleOff
                    end
                end
            end
        end

    elseif element.Type == "ImageLabel" then
        local img = frame:FindFirstChild("Image")
        if img then
            local stroke = img:FindFirstChildOfClass("UIStroke")
            if stroke then
                stroke.Color = Config.Theme.Border
            end
        end

    elseif element.Type == "GroupBox" then
        frame.BackgroundColor3 = Config.Theme.Background
        local stroke = frame:FindFirstChildOfClass("UIStroke")
        if stroke then
            stroke.Color = Config.Theme.Border
        end
        local title = frame:FindFirstChild("Title")
        if title then
            title.Font = Config.Theme.Font
            title.TextSize = 11
            title.TextColor3 = Config.Theme.Accent
        end

    elseif element.Type == "ListBox" then
        frame.BackgroundColor3 = Config.Theme.ElementBackground
        local list = frame:FindFirstChild("List")
        if list then
            list.BackgroundColor3 = Config.Theme.TitleBar
            for _, child in pairs(list:GetChildren()) do
                if child:IsA("TextButton") then
                    child.Font = Config.Theme.Font
                    child.TextSize = 11
                    child.TextColor3 = (child.Name == tostring(element.Value)) and Config.Theme.Accent or Config.Theme.Text
                end
            end
        end

    elseif element.Type == "StatusBar" then
        frame.BackgroundColor3 = Config.Theme.TitleBar
        local text = frame:FindFirstChild("Text")
        if text then
            text.Font = Config.Theme.Font
            text.TextSize = 10
            text.TextColor3 = Config.Theme.TextDisabled
        end
    end
end

function Library:UpdateTheme()
    if not ScreenGui then return end

    for id, window in pairs(Windows) do
        if type(id) == "string" and window.Frame then
            local frame = window.Frame
            frame.BackgroundColor3 = Config.Theme.Background
            frame.BackgroundTransparency = Config.Theme.BackgroundTransparency

            local stroke = frame:FindFirstChildOfClass("UIStroke")
            if stroke then
                stroke.Color = Config.Theme.Border
            end

            local titleBar = frame:FindFirstChild("TitleBar")
            if titleBar then
                titleBar.BackgroundColor3 = Config.Theme.TitleBar
                local title = titleBar:FindFirstChild("Title")
                if title then
                    title.Font = Config.Theme.Font
                    title.TextColor3 = Config.Theme.Text
                    title.TextSize = Config.Theme.TextSize
                end
                local closeBtn = titleBar:FindFirstChild("Close")
                if closeBtn then
                    closeBtn.Font = Config.Theme.Font
                    closeBtn.TextColor3 = Config.Theme.Text
                end
                local collapseBtn = titleBar:FindFirstChild("Collapse")
                if collapseBtn then
                    collapseBtn.Font = Config.Theme.Font
                    collapseBtn.TextColor3 = Config.Theme.Text
                end
            end

            if window.Elements then
                for _, element in pairs(window.Elements) do
                    self:UpdateElementTheme(element)
                end
            end
        end
    end
end

-- Window Creation
function Library:CreateWindow(title, position)
    self:Init()

    local windowId = title .. "_" .. tostring(#Windows + 1)

    local Window = {
        Id = windowId,
        Title = title,
        Elements = {},
        Visible = true,
        Position = position or UDim2.new(0, 50 + (#Windows * 200), 0, 50),
    }

    -- Window Frame
    local WindowFrame = CreateInstance("Frame", {
        Name = title,
        Parent = MainFrame,
        BackgroundColor3 = Config.Theme.Background,
        BackgroundTransparency = Config.Theme.BackgroundTransparency,
        BorderSizePixel = 0,
        Size = UDim2.new(0, Config.Theme.WindowWidth, 0, Config.Theme.TitleBarHeight),
        Position = Window.Position,
        ClipsDescendants = true,
        Active = true,
    })
    CreateCorner(WindowFrame)
    CreateStroke(WindowFrame)

    -- Title Bar
    local TitleBar = CreateInstance("Frame", {
        Name = "TitleBar",
        Parent = WindowFrame,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.TitleBarHeight),
        Active = true,
    })
    CreateCorner(TitleBar)

    -- Title Label
    local TitleLabel = CreateInstance("TextLabel", {
        Name = "Title",
        Parent = TitleBar,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        Font = Config.Theme.Font,
        Text = title,
        TextColor3 = Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- Close Button
    local CloseButton = CreateInstance("TextButton", {
        Name = "Close",
        Parent = TitleBar,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -22, 0, 1),
        Font = Config.Theme.Font,
        Text = "X",
        TextColor3 = Config.Theme.Text,
        TextSize = 14,
    })

    CloseButton.MouseButton1Click:Connect(function()
        WindowFrame.Visible = false
        Window.Visible = false
    end)

    -- Content Container (defined BEFORE CollapseButton uses it)
    local ContentContainer = CreateInstance("Frame", {
        Name = "Content",
        Parent = WindowFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 0, 0),
        Position = UDim2.new(0, 4, 0, Config.Theme.TitleBarHeight + 2),
        ClipsDescendants = true,
    })
    CreatePadding(ContentContainer, 2)

    local ContentLayout = CreateListLayout(ContentContainer, 2)

    -- Collapse Button (moved AFTER ContentContainer is defined)
    local CollapseButton = CreateInstance("TextButton", {
        Name = "Collapse",
        Parent = TitleBar,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -44, 0, 1),
        Font = Config.Theme.Font,
        Text = "-",
        TextColor3 = Config.Theme.Text,
        TextSize = 14,
    })

    local collapsed = false
    CollapseButton.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        ContentContainer.Visible = not collapsed
        if collapsed then
            WindowFrame.Size = UDim2.new(0, Config.Theme.WindowWidth, 0, Config.Theme.TitleBarHeight)
            CollapseButton.Text = "+"
        else
            WindowFrame.Size = UDim2.new(0, Config.Theme.WindowWidth, 0, 
                Config.Theme.TitleBarHeight + ContentContainer.Size.Y.Offset + 4)
            CollapseButton.Text = "-"
        end
    end)

    -- Update window size when content changes
    ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if not collapsed then
            local contentHeight = ContentLayout.AbsoluteContentSize.Y
            ContentContainer.Size = UDim2.new(1, -8, 0, contentHeight)
            WindowFrame.Size = UDim2.new(0, Config.Theme.WindowWidth, 0, 
                Config.Theme.TitleBarHeight + contentHeight + 6)
        end
    end)

    -- Make draggable
    MakeDraggable(WindowFrame, TitleBar)

    -- Bring to front on click
    WindowFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            WindowFrame.ZIndex = #Windows + 10
            for id, win in pairs(Windows) do
                if type(id) == "string" and win ~= Window then
                    win.Frame.ZIndex = 1
                end
            end
        end
    end)

    Window.Frame = WindowFrame
    Window.Content = ContentContainer
    Window.Layout = ContentLayout

    -- Apply saved position if exists (always force visible)
    if self.PendingConfig and self.PendingConfig.Windows and self.PendingConfig.Windows[windowId] then
        local data = self.PendingConfig.Windows[windowId]
        if data.Position then
            WindowFrame.Position = UDim2.new(
                data.Position.X[1], data.Position.X[2],
                data.Position.Y[1], data.Position.Y[2]
            )
        end
        WindowFrame.Visible = true
        Window.Visible = true
        self.PendingConfig.Windows[windowId] = nil
    end

    table.insert(Windows, Window)
    Windows[windowId] = Window

    return Window
end

-- Toggle Element
function Library:CreateToggle(window, text, default, callback, flag)
    local Toggle = {
        Type = "Toggle",
        Value = default or false,
        Flag = flag or text .. "_Toggle",
        Callback = callback,
        Window = window,
    }

    local ToggleFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
    })
    CreateCorner(ToggleFrame)

    local ToggleButton = CreateInstance("TextButton", {
        Name = "Button",
        Parent = ToggleFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = default and Config.Theme.ToggleOn or Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    CreatePadding(ToggleButton, 6)

    local Indicator = CreateInstance("Frame", {
        Name = "Indicator",
        Parent = ToggleFrame,
        BackgroundColor3 = default and Config.Theme.ToggleOn or Config.Theme.ToggleOff,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(1, -14, 0.5, -4),
    })
    CreateCorner(Indicator, UDim.new(1, 0))

    local function SetValue(value)
        Toggle.Value = value
        ToggleButton.TextColor3 = value and Config.Theme.ToggleOn or Config.Theme.Text
        Indicator.BackgroundColor3 = value and Config.Theme.ToggleOn or Config.Theme.ToggleOff

        if callback then
            task.spawn(function()
                local success, err = pcall(callback, value)
                if not success then
                    warn("Toggle callback error: " .. tostring(err))
                end
            end)
        end

        -- Save to config
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    ToggleButton.MouseButton1Click:Connect(function()
        SetValue(not Toggle.Value)
    end)

    -- Hover effects
    ToggleFrame.MouseEnter:Connect(function()
        ToggleFrame.BackgroundColor3 = Config.Theme.ElementHover
    end)
    ToggleFrame.MouseLeave:Connect(function()
        ToggleFrame.BackgroundColor3 = Config.Theme.ElementBackground
    end)

