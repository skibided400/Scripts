-- Tooltip System
function Library:ShowTooltip(parent, text)
    if not ScreenGui then return end
    self:HideTooltip()

    local Tooltip = CreateInstance("Frame", {
        Name = "Tooltip",
        Parent = ScreenGui,
        BackgroundColor3 = Config.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 0, 0),
        ZIndex = 100,
    })
    CreateCorner(Tooltip)
    CreateStroke(Tooltip)
    CreatePadding(Tooltip, 6)

    local Label = CreateInstance("TextLabel", {
        Parent = Tooltip,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 0, 0, 0),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = Config.Theme.Text,
        TextSize = 12,
        TextWrapped = true,
        AutomaticSize = Enum.AutomaticSize.XY,
    })

    task.wait()
    local absPos = parent.AbsolutePosition
    local absSize = parent.AbsoluteSize
    Tooltip.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 4)

    -- Keep tooltip within screen bounds
    local tooltipSize = Tooltip.AbsoluteSize
    local screenSize = ScreenGui.AbsoluteSize
    if Tooltip.AbsolutePosition.X + tooltipSize.X > screenSize.X then
        Tooltip.Position = UDim2.new(0, screenSize.X - tooltipSize.X - 10, 0, Tooltip.AbsolutePosition.Y)
    end
    if Tooltip.AbsolutePosition.Y + tooltipSize.Y > screenSize.Y then
        Tooltip.Position = UDim2.new(0, Tooltip.AbsolutePosition.X, 0, absPos.Y - tooltipSize.Y - 4)
    end

    self.CurrentTooltip = Tooltip
end

function Library:HideTooltip()
    if self.CurrentTooltip then
        self.CurrentTooltip:Destroy()
        self.CurrentTooltip = nil
    end
end

-- Config System
function Library:SaveConfig()
    local config = {
        Windows = {},
        Elements = {},
        Theme = {},
    }

    -- Save window positions (visibility is NOT saved)
    for id, window in pairs(Windows) do
        if type(id) == "string" and window.Frame then
            config.Windows[window.Id] = {
                Position = {
                    X = {window.Frame.Position.X.Scale, window.Frame.Position.X.Offset},
                    Y = {window.Frame.Position.Y.Scale, window.Frame.Position.Y.Offset},
                },
            }
        end
    end

    -- Save element values
    for flag, element in pairs(Elements) do
        if element.Type == "Toggle" then
            config.Elements[flag] = {Type = "Toggle", Value = element.Value}
        elseif element.Type == "TextBox" then
            config.Elements[flag] = {Type = "TextBox", Value = element.Value}
        elseif element.Type == "Dropdown" then
            config.Elements[flag] = {Type = "Dropdown", Value = element.Value}
        elseif element.Type == "Slider" then
            config.Elements[flag] = {Type = "Slider", Value = element.Value}
        elseif element.Type == "ColorPicker" then
            config.Elements[flag] = {
                Type = "ColorPicker", 
                Value = {element.Value.R, element.Value.G, element.Value.B}
            }
        elseif element.Type == "Keybind" then
            config.Elements[flag] = {Type = "Keybind", Value = element.Value.Name}
        elseif element.Type == "MultiDropdown" then
            config.Elements[flag] = {Type = "MultiDropdown", Value = element.Value}
        elseif element.Type == "NumberBox" then
            config.Elements[flag] = {Type = "NumberBox", Value = element.Value}
        elseif element.Type == "RadioButtonSet" then
            config.Elements[flag] = {Type = "RadioButtonSet", Value = element.Value}
        elseif element.Type == "ListBox" then
            config.Elements[flag] = {Type = "ListBox", Value = element.Value}
        end
    end

    -- Save theme
    config.Theme = {
        Background = {Config.Theme.Background.R, Config.Theme.Background.G, Config.Theme.Background.B},
        Accent = {Config.Theme.Accent.R, Config.Theme.Accent.G, Config.Theme.Accent.B},
    }

    local success, encoded = pcall(HttpService.JSONEncode, HttpService, config)
    if success then
        pcall(function()
            writefile(Config.SaveFile, encoded)
        end)
    end
end

function Library:LoadConfig()
    local success, content = pcall(function()
        return readfile(Config.SaveFile)
    end)

    if not success or not content then return end

    local decoded
    success, decoded = pcall(HttpService.JSONDecode, HttpService, content)
    if not success or not decoded then return end

    -- Store for later application (elements may not exist yet)
    self.PendingConfig = decoded
end

function Library:ApplyConfig()
    if not self.PendingConfig then return end

    local config = self.PendingConfig

    -- Apply window positions (always force visible)
    if config.Windows then
        for id, data in pairs(config.Windows) do
            if type(id) == "string" then
                local window = Windows[id]
                if window and window.Frame and data.Position then
                    window.Frame.Position = UDim2.new(
                        data.Position.X[1], data.Position.X[2],
                        data.Position.Y[1], data.Position.Y[2]
                    )
                    window.Frame.Visible = true
                    window.Visible = true
                end
            end
        end
    end

    -- Apply theme
    if config.Theme then
        if config.Theme.Background then
            Config.Theme.Background = Color3.new(unpack(config.Theme.Background))
        end
        if config.Theme.Accent then
            Config.Theme.Accent = Color3.new(unpack(config.Theme.Accent))
        end
        self:UpdateTheme()
    end

    -- Apply element values to EXISTING elements
    if config.Elements then
        for flag, data in pairs(config.Elements) do
            local element = Elements[flag]
            if element and element.Set then
                if data.Type == "Toggle" then
                    element.Set(data.Value)
                elseif data.Type == "TextBox" then
                    element.Set(data.Value)
                elseif data.Type == "Dropdown" then
                    element.Set(data.Value)
                elseif data.Type == "Slider" then
                    element.Set(data.Value)
                elseif data.Type == "ColorPicker" then
                    element.Set(Color3.new(data.Value[1], data.Value[2], data.Value[3]))
                elseif data.Type == "Keybind" then
                    local keyCode = Enum.KeyCode[data.Value]
                    if keyCode then
                        element.Set(keyCode)
                    end
                elseif data.Type == "MultiDropdown" then
                    element.Set(data.Value)
                elseif data.Type == "NumberBox" then
                    element.Set(data.Value)
                elseif data.Type == "RadioButtonSet" then
                    element.Set(data.Value)
                elseif data.Type == "ListBox" then
                    element.Set(data.Value)
                end
            end
        end
    end

    -- Note: we do NOT clear PendingConfig so late-created elements can still use it
end

-- Toggle UI Visibility
function Library:ToggleUI()
    if ScreenGui then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end

-- Destroy UI
function Library:Destroy()
    self:SaveConfig()
    if ScreenGui then
        ScreenGui:Destroy()
        ScreenGui = nil
        Library.ScreenGui = nil
    end
    Windows = {}
    Library.Windows = {}
    Elements = {}
    Library.Elements = {}
end

-- Set Theme
function Library:SetTheme(themeTable)
    for key, value in pairs(themeTable) do
        if Config.Theme[key] ~= nil then
            Config.Theme[key] = value
        end
    end
    self:UpdateTheme()
end

-- Set Save File
function Library:SetSaveFile(filename)
    Config.SaveFile = filename
    self:LoadConfig()
end

-- Notification System
function Library:Notify(text, duration)
    duration = duration or 3

    local NotifyFrame = CreateInstance("Frame", {
        Parent = ScreenGui,
        BackgroundColor3 = Config.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 250, 0, 40),
        Position = UDim2.new(1, -260, 1, -50),
    })
    CreateCorner(NotifyFrame)
    CreateStroke(NotifyFrame)

    local NotifyLabel = CreateInstance("TextLabel", {
        Parent = NotifyFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -10, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = Config.Theme.Text,
        TextSize = 13,
        TextWrapped = true,
    })

    -- Animate in
    NotifyFrame.Position = UDim2.new(1, 0, 1, -50)
    TweenService:Create(NotifyFrame, TweenInfo.new(0.3), {
        Position = UDim2.new(1, -260, 1, -50)
    }):Play()

    task.delay(duration, function()
        TweenService:Create(NotifyFrame, TweenInfo.new(0.3), {
            Position = UDim2.new(1, 0, 1, -50)
        }):Play()
        task.wait(0.3)
        NotifyFrame:Destroy()
    end)
end

-- EXTERNAL ACCESS HELPERS
-- Get any element by its flag
function Library:GetElement(flag)
    return Elements[flag]
end

-- Get element value by flag
function Library:GetValue(flag)
    local element = Elements[flag]
    if element then
        return element.Value
    end
    return nil
end

-- Set element value by flag (works for Toggle, TextBox, Dropdown, Slider, ColorPicker, Keybind, MultiDropdown, NumberBox, RadioButtonSet, ListBox)
function Library:SetValue(flag, value)
    local element = Elements[flag]
    if element and element.Set then
        element.Set(value)
        return true
    end
    return false
end

-- Get all elements of a specific type
function Library:GetElementsByType(elementType)
    local result = {}
    for flag, element in pairs(Elements) do
        if element.Type == elementType then
            result[flag] = element
        end
    end
    return result
end

-- Get window by title or id
function Library:GetWindow(id)
    return Windows[id]
end

-- Set theme value directly
function Library:SetThemeValue(key, value)
    if Config.Theme[key] ~= nil then
        Config.Theme[key] = value
        return true
    end
    return false
end

-- Get theme value
function Library:GetThemeValue(key)
    return Config.Theme[key]
end

-- Update config setting
function Library:SetConfig(key, value)
    if Config[key] ~= nil then
        Config[key] = value
        return true
    end
    return false
end

-- Get config setting
function Library:GetConfig(key)
    return Config[key]
end

return Library
