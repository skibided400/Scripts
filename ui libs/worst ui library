-- ListBox Element (scrollable selectable list)
function Library:CreateListBox(window, text, options, default, callback, flag)
    local ListBox = {
        Type = "ListBox",
        Options = options or {},
        Value = default or (options and options[1]) or "",
        Flag = flag or text .. "_ListBox",
        Callback = callback,
        Window = window,
    }

    local ListFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 100),
        ClipsDescendants = true,
    })
    CreateCorner(ListFrame)
    CreatePadding(ListFrame, 2)

    local Label = CreateInstance("TextLabel", {
        Name = "Label",
        Parent = ListFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 14),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = Config.Theme.Text,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local ListContainer = CreateInstance("ScrollingFrame", {
        Name = "List",
        Parent = ListFrame,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, -16),
        Position = UDim2.new(0, 0, 0, 16),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Config.Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    })
    CreateCorner(ListContainer)
    CreatePadding(ListContainer, 2)
    local ListLayout = CreateListLayout(ListContainer, 1)

    local function BuildList()
        for _, child in pairs(ListContainer:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        for _, option in pairs(ListBox.Options) do
            local ItemBtn = CreateInstance("TextButton", {
                Name = option,
                Parent = ListContainer,
                BackgroundColor3 = option == ListBox.Value and Config.Theme.Accent or Config.Theme.TitleBar,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 20),
                Font = Config.Theme.Font,
                Text = tostring(option),
                TextColor3 = option == ListBox.Value and Config.Theme.Background or Config.Theme.Text,
                TextSize = 11,
            })
            CreateCorner(ItemBtn)

            ItemBtn.MouseButton1Click:Connect(function()
                ListBox.Value = option
                for _, child in pairs(ListContainer:GetChildren()) do
                    if child:IsA("TextButton") then
                        local isSelected = child.Name == option
                        child.BackgroundColor3 = isSelected and Config.Theme.Accent or Config.Theme.TitleBar
                        child.TextColor3 = isSelected and Config.Theme.Background or Config.Theme.Text
                    end
                end

                if callback then
                    task.spawn(function()
                        local success, err = pcall(callback, option)
                        if not success then
                            warn("ListBox callback error: " .. tostring(err))
                        end
                    end)
                end
                if Config.AutoSave then
                    self:SaveConfig()
                end
            end)

            ItemBtn.MouseEnter:Connect(function()
                if ItemBtn.Name ~= ListBox.Value then
                    ItemBtn.BackgroundColor3 = Config.Theme.ElementHover
                end
            end)
            ItemBtn.MouseLeave:Connect(function()
                if ItemBtn.Name ~= ListBox.Value then
                    ItemBtn.BackgroundColor3 = Config.Theme.TitleBar
                end
            end)
        end
    end

    BuildList()

    local function SetValue(value)
        ListBox.Value = value
        for _, child in pairs(ListContainer:GetChildren()) do
            if child:IsA("TextButton") then
                local isSelected = child.Name == value
                child.BackgroundColor3 = isSelected and Config.Theme.Accent or Config.Theme.TitleBar
                child.TextColor3 = isSelected and Config.Theme.Background or Config.Theme.Text
            end
        end
        if callback then
            task.spawn(function()
                pcall(callback, value)
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    ListBox.Set = SetValue
    ListBox.AddOption = function(option)
        table.insert(ListBox.Options, option)
        BuildList()
    end
    ListBox.RemoveOption = function(option)
        for i, opt in pairs(ListBox.Options) do
            if opt == option then
                table.remove(ListBox.Options, i)
                break
            end
        end
        BuildList()
    end
    ListBox.Frame = ListFrame
    Elements[ListBox.Flag] = ListBox
    table.insert(window.Elements, ListBox)

    ApplyPendingElementConfig(self, ListBox, "ListBox")

    return ListBox
end

