function Library:CreateKeybind(window, text, default, callback, flag)
    local Keybind = {
        Type = "Keybind",
        Value = default or Enum.KeyCode.Unknown,
        Flag = flag or text .. "_Keybind",
        Callback = callback,
        Listening = false,
    }

    local KeybindFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
    })
    CreateCorner(KeybindFrame)

    local Label = CreateInstance("TextLabel", {
        Name = "Label",
        Parent = KeybindFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, 6, 0, 0),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local KeyButton = CreateInstance("TextButton", {
        Name = "Key",
        Parent = KeybindFrame,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 50, 0, 18),
        Position = UDim2.new(1, -54, 0.5, -9),
        Font = Config.Theme.Font,
        Text = default and default.Name or "None",
        TextColor3 = Config.Theme.Text,
        TextSize = 10,
    })
    CreateCorner(KeyButton)

    local function SetKey(key)
        Keybind.Value = key
        KeyButton.Text = key and key.Name or "None"
        Keybind.Listening = false
        KeyButton.TextColor3 = Config.Theme.Text

        if callback then
            task.spawn(function()
                local success, err = pcall(callback, key)
                if not success then
                    warn("Keybind callback error: " .. tostring(err))
                end
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    KeyButton.MouseButton1Click:Connect(function()
        Keybind.Listening = true
        KeyButton.Text = "..."
        KeyButton.TextColor3 = Config.Theme.Accent
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if Keybind.Listening and not gameProcessed then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                SetKey(input.KeyCode)
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                SetKey(Enum.UserInputType.MouseButton1)
            elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                SetKey(Enum.UserInputType.MouseButton2)
            end
        elseif not gameProcessed and Keybind.Value ~= Enum.KeyCode.Unknown then
            if input.KeyCode == Keybind.Value or input.UserInputType == Keybind.Value then
                if callback then
                    task.spawn(function()
                        pcall(callback, Keybind.Value, true)
                    end)
                end
            end
        end
    end)

    Keybind.Set = SetKey
    Keybind.Frame = KeybindFrame
    Elements[Keybind.Flag] = Keybind
    table.insert(window.Elements, Keybind)

    return Keybind
end

