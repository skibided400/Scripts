        TextXAlignment = Enum.TextXAlignment.Center, -- CENTER HORIZONTALLY
        TextYAlignment = Enum.TextYAlignment.Center, -- CENTER VERTICALLY
    })

    local InputContainer = CreateInstance("Frame", {
        Name = "InputContainer",
        Parent = BoxFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 18),
