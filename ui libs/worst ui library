-- WurstStyle UI Library for Roblox
-- A per-window ClickGUI style UI library with saving support

local Library = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")

-- Configuration
local Config = {
    Theme = {
        Background = Color3.fromRGB(30, 30, 30),
        BackgroundTransparency = 0.15,
        TitleBar = Color3.fromRGB(40, 40, 40),
        TitleBarHeight = 22,
        Accent = Color3.fromRGB(0, 200, 0), -- Green accent like Wurst
        Text = Color3.fromRGB(255, 255, 255),
        TextDisabled = Color3.fromRGB(150, 150, 150),
        ElementBackground = Color3.fromRGB(45, 45, 45),
        ElementHover = Color3.fromRGB(55, 55, 55),
        ToggleOn = Color3.fromRGB(0, 200, 0),
        ToggleOff = Color3.fromRGB(60, 60, 60),
        Border = Color3.fromRGB(60, 60, 60),
        WindowWidth = 180,
        ElementHeight = 24,
        Padding = 4,
        CornerRadius = UDim.new(0, 2),
        Font = Enum.Font.Code,
        TextSize = 13,
    },
    SaveFile = "WurstUI_Config.json",
    AutoSave = true,
    SaveInterval = 30, -- seconds
}

-- State
local Windows = {}
local Elements = {}
local Callbacks = {}
local Dragging = nil
local DragOffset = nil
local ScreenGui = nil
local MainFrame = nil
local SaveTimer = nil

-- Utility Functions
local function MakeDraggable(obj, dragHandle)
    dragHandle = dragHandle or obj
    local dragging = false
    local dragStart = nil
    local startPos = nil

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local function CreateInstance(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        instance[prop] = value
    end
    return instance
end

local function CreateCorner(parent, radius)
    local corner = CreateInstance("UICorner", {
        Parent = parent,
        CornerRadius = radius or Config.Theme.CornerRadius,
    })
    return corner
end

local function CreateStroke(parent, color, thickness)
    local stroke = CreateInstance("UIStroke", {
        Parent = parent,
        Color = color or Config.Theme.Border,
        Thickness = thickness or 1,
    })
    return stroke
end

local function CreatePadding(parent, padding)
    local pad = CreateInstance("UIPadding", {
        Parent = parent,
        PaddingLeft = UDim.new(0, padding or Config.Theme.Padding),
        PaddingRight = UDim.new(0, padding or Config.Theme.Padding),
        PaddingTop = UDim.new(0, padding or Config.Theme.Padding),
        PaddingBottom = UDim.new(0, padding or Config.Theme.Padding),
    })
    return pad
end

local function CreateListLayout(parent, padding)
    local layout = CreateInstance("UIListLayout", {
        Parent = parent,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, padding or 2),
    })
    return layout
end

-- Initialize UI
function Library:Init()
    if ScreenGui then return end

    ScreenGui = CreateInstance("ScreenGui", {
        Name = "WurstUI",
        Parent = CoreGui,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
    })

    MainFrame = CreateInstance("Frame", {
        Name = "Main",
        Parent = ScreenGui,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
    })

    -- Load saved config
    self:LoadConfig()

    -- Auto-save loop
    if Config.AutoSave then
        task.spawn(function()
            while ScreenGui and ScreenGui.Parent do
                task.wait(Config.SaveInterval)
                if ScreenGui and ScreenGui.Parent then
                    self:SaveConfig()
                end
            end
        end)
    end

    -- Save on player leaving
    game.Players.LocalPlayer.CharacterRemoving:Connect(function()
        self:SaveConfig()
    end)
end

-- Window Creation
function Library:CreateWindow(title, position)
    self:Init()

    local windowId = title .. "_" .. tostring(#Windows + 1)

    local Window = {
        Id = windowId,
        Title = title,
        Elements = {},
        Visible = true,
        Position = position or UDim2.new(0, 50 + (#Windows * 200), 0, 50),
    }

    -- Window Frame
    local WindowFrame = CreateInstance("Frame", {
        Name = title,
        Parent = MainFrame,
        BackgroundColor3 = Config.Theme.Background,
        BackgroundTransparency = Config.Theme.BackgroundTransparency,
        BorderSizePixel = 0,
        Size = UDim2.new(0, Config.Theme.WindowWidth, 0, Config.Theme.TitleBarHeight),
        Position = Window.Position,
        ClipsDescendants = true,
        Active = true,
    })
    CreateCorner(WindowFrame)
    CreateStroke(WindowFrame)

    -- Title Bar
    local TitleBar = CreateInstance("Frame", {
        Name = "TitleBar",
        Parent = WindowFrame,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.TitleBarHeight),
        Active = true,
    })
    CreateCorner(TitleBar)

    -- Title Label
    local TitleLabel = CreateInstance("TextLabel", {
        Name = "Title",
        Parent = TitleBar,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        Font = Config.Theme.Font,
        Text = title,
        TextColor3 = Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- Close Button
    local CloseButton = CreateInstance("TextButton", {
        Name = "Close",
        Parent = TitleBar,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -22, 0, 1),
        Font = Config.Theme.Font,
        Text = "X",
        TextColor3 = Config.Theme.Text,
        TextSize = 14,
    })

    CloseButton.MouseButton1Click:Connect(function()
        WindowFrame.Visible = false
        Window.Visible = false
    end)

    -- Content Container (defined BEFORE CollapseButton uses it)
    local ContentContainer = CreateInstance("Frame", {
        Name = "Content",
        Parent = WindowFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 0, 0),
        Position = UDim2.new(0, 4, 0, Config.Theme.TitleBarHeight + 2),
        ClipsDescendants = true,
    })
    CreatePadding(ContentContainer, 2)

    local ContentLayout = CreateListLayout(ContentContainer, 2)

    -- Collapse Button (moved AFTER ContentContainer is defined)
    local CollapseButton = CreateInstance("TextButton", {
        Name = "Collapse",
        Parent = TitleBar,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 20, 0, 20),
        Position = UDim2.new(1, -44, 0, 1),
        Font = Config.Theme.Font,
        Text = "-",
        TextColor3 = Config.Theme.Text,
        TextSize = 14,
    })

    local collapsed = false
    CollapseButton.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        ContentContainer.Visible = not collapsed
        if collapsed then
            WindowFrame.Size = UDim2.new(0, Config.Theme.WindowWidth, 0, Config.Theme.TitleBarHeight)
            CollapseButton.Text = "+"
        else
            WindowFrame.Size = UDim2.new(0, Config.Theme.WindowWidth, 0, 
                Config.Theme.TitleBarHeight + ContentContainer.Size.Y.Offset + 4)
            CollapseButton.Text = "-"
        end
    end)

    -- Update window size when content changes
    ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if not collapsed then
            local contentHeight = ContentLayout.AbsoluteContentSize.Y
            ContentContainer.Size = UDim2.new(1, -8, 0, contentHeight)
            WindowFrame.Size = UDim2.new(0, Config.Theme.WindowWidth, 0, 
                Config.Theme.TitleBarHeight + contentHeight + 6)
        end
    end)

    -- Make draggable
    MakeDraggable(WindowFrame, TitleBar)

    -- Bring to front on click
    WindowFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            WindowFrame.ZIndex = #Windows + 10
            for _, win in pairs(Windows) do
                if win ~= Window then
                    win.Frame.ZIndex = 1
                end
            end
        end
    end)

    Window.Frame = WindowFrame
    Window.Content = ContentContainer
    Window.Layout = ContentLayout

    table.insert(Windows, Window)
    Windows[windowId] = Window

    return Window
end

-- Toggle Element
function Library:CreateToggle(window, text, default, callback, flag)
    local Toggle = {
        Type = "Toggle",
        Value = default or false,
        Flag = flag or text .. "_Toggle",
        Callback = callback,
    }

    local ToggleFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
    })
    CreateCorner(ToggleFrame)

    local ToggleButton = CreateInstance("TextButton", {
        Name = "Button",
        Parent = ToggleFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = default and Config.Theme.ToggleOn or Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    CreatePadding(ToggleButton, 6)

    local Indicator = CreateInstance("Frame", {
        Name = "Indicator",
        Parent = ToggleFrame,
        BackgroundColor3 = default and Config.Theme.ToggleOn or Config.Theme.ToggleOff,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(1, -14, 0.5, -4),
    })
    CreateCorner(Indicator, UDim.new(1, 0))

    local function SetValue(value)
        Toggle.Value = value
        ToggleButton.TextColor3 = value and Config.Theme.ToggleOn or Config.Theme.Text
        Indicator.BackgroundColor3 = value and Config.Theme.ToggleOn or Config.Theme.ToggleOff

        if callback then
            task.spawn(function()
                local success, err = pcall(callback, value)
                if not success then
                    warn("Toggle callback error: " .. tostring(err))
                end
            end)
        end

        -- Save to config
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    ToggleButton.MouseButton1Click:Connect(function()
        SetValue(not Toggle.Value)
    end)

    -- Hover effects
    ToggleFrame.MouseEnter:Connect(function()
        ToggleFrame.BackgroundColor3 = Config.Theme.ElementHover
    end)
    ToggleFrame.MouseLeave:Connect(function()
        ToggleFrame.BackgroundColor3 = Config.Theme.ElementBackground
    end)

    Toggle.Set = SetValue
    Toggle.Frame = ToggleFrame

    -- Store for config loading
    Elements[Toggle.Flag] = Toggle
    table.insert(window.Elements, Toggle)

    return Toggle
end

-- Button Element
function Library:CreateButton(window, text, callback)
    local Button = {
        Type = "Button",
        Callback = callback,
    }

    local ButtonFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
    })
    CreateCorner(ButtonFrame)

    local ButtonObj = CreateInstance("TextButton", {
        Name = "Button",
        Parent = ButtonFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
    })
    CreatePadding(ButtonObj, 6)

    ButtonObj.MouseButton1Click:Connect(function()
        if callback then
            task.spawn(function()
                local success, err = pcall(callback)
                if not success then
                    warn("Button callback error: " .. tostring(err))
                end
            end)
        end

        -- Click animation
        TweenService:Create(ButtonFrame, TweenInfo.new(0.1), {
            BackgroundColor3 = Config.Theme.Accent
        }):Play()
        task.wait(0.1)
        TweenService:Create(ButtonFrame, TweenInfo.new(0.1), {
            BackgroundColor3 = Config.Theme.ElementBackground
        }):Play()
    end)

    ButtonFrame.MouseEnter:Connect(function()
        ButtonFrame.BackgroundColor3 = Config.Theme.ElementHover
    end)
    ButtonFrame.MouseLeave:Connect(function()
        ButtonFrame.BackgroundColor3 = Config.Theme.ElementBackground
    end)

    Button.Frame = ButtonFrame
    table.insert(window.Elements, Button)

    return Button
end

-- TextBox Element
function Library:CreateTextBox(window, text, placeholder, default, callback, flag)
    local TextBox = {
        Type = "TextBox",
        Value = default or "",
        Flag = flag or text .. "_TextBox",
        Callback = callback,
    }

    local BoxFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight + 4),
    })
    CreateCorner(BoxFrame)
    CreatePadding(BoxFrame, 4)

    local Label = CreateInstance("TextLabel", {
        Name = "Label",
        Parent = BoxFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 14),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = Config.Theme.Text,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local InputBox = CreateInstance("TextBox", {
        Name = "Input",
        Parent = BoxFrame,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 18),
        Position = UDim2.new(0, 0, 0, 14),
        Font = Config.Theme.Font,
        Text = default or "",
        PlaceholderText = placeholder or "Enter text...",
        TextColor3 = Config.Theme.Text,
        TextSize = 11,
        ClearTextOnFocus = false,
    })
    CreateCorner(InputBox)
    CreatePadding(InputBox, 4)

    local function SetValue(value)
        TextBox.Value = value
        InputBox.Text = tostring(value)
        if callback then
            task.spawn(function()
                local success, err = pcall(callback, value)
                if not success then
                    warn("TextBox callback error: " .. tostring(err))
                end
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    InputBox.FocusLost:Connect(function(enterPressed)
        SetValue(InputBox.Text)
    end)

    TextBox.Set = SetValue
    TextBox.Frame = BoxFrame
    Elements[TextBox.Flag] = TextBox
    table.insert(window.Elements, TextBox)

    return TextBox
end

-- Dropdown Element
function Library:CreateDropdown(window, text, options, default, callback, flag)
    local Dropdown = {
        Type = "Dropdown",
        Options = options or {},
        Value = default or (options and options[1]) or "",
        Flag = flag or text .. "_Dropdown",
        Callback = callback,
        Open = false,
    }

    local DropdownFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
        ClipsDescendants = true,
    })
    CreateCorner(DropdownFrame)

    local DropdownButton = CreateInstance("TextButton", {
        Name = "Button",
        Parent = DropdownFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight),
        Font = Config.Theme.Font,
        Text = text .. ": " .. tostring(Dropdown.Value),
        TextColor3 = Config.Theme.Text,
        TextSize = Config.Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    CreatePadding(DropdownButton, 6)

    local Arrow = CreateInstance("TextLabel", {
        Name = "Arrow",
        Parent = DropdownButton,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 16, 1, 0),
        Position = UDim2.new(1, -16, 0, 0),
        Font = Config.Theme.Font,
        Text = "▼",
        TextColor3 = Config.Theme.Text,
        TextSize = 10,
    })

    local OptionsContainer = CreateInstance("Frame", {
        Name = "Options",
        Parent = DropdownFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, Config.Theme.ElementHeight),
    })
    CreatePadding(OptionsContainer, 2)
    local OptionsLayout = CreateListLayout(OptionsContainer, 1)

    local function BuildOptions()
        for _, child in pairs(OptionsContainer:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        for _, option in pairs(Dropdown.Options) do
            local OptionBtn = CreateInstance("TextButton", {
                Name = option,
                Parent = OptionsContainer,
                BackgroundColor3 = Config.Theme.TitleBar,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 20),
                Font = Config.Theme.Font,
                Text = tostring(option),
                TextColor3 = option == Dropdown.Value and Config.Theme.Accent or Config.Theme.Text,
                TextSize = 11,
            })
            CreateCorner(OptionBtn)

            OptionBtn.MouseButton1Click:Connect(function()
                Dropdown.Value = option
                DropdownButton.Text = text .. ": " .. tostring(option)
                Dropdown.Open = false
                DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight)
                Arrow.Text = "▼"

                if callback then
                    task.spawn(function()
                        local success, err = pcall(callback, option)
                        if not success then
                            warn("Dropdown callback error: " .. tostring(err))
                        end
                    end)
                end

                if Config.AutoSave then
                    self:SaveConfig()
                end
            end)

            OptionBtn.MouseEnter:Connect(function()
                OptionBtn.BackgroundColor3 = Config.Theme.ElementHover
            end)
            OptionBtn.MouseLeave:Connect(function()
                OptionBtn.BackgroundColor3 = Config.Theme.TitleBar
            end)
        end
    end

    BuildOptions()

    DropdownButton.MouseButton1Click:Connect(function()
        Dropdown.Open = not Dropdown.Open
        if Dropdown.Open then
            local optionsHeight = math.min(#Dropdown.Options * 21, 150)
            DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight + optionsHeight)
            Arrow.Text = "▲"
        else
            DropdownFrame.Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight)
            Arrow.Text = "▼"
        end
    end)

    Dropdown.Set = function(value)
        Dropdown.Value = value
        DropdownButton.Text = text .. ": " .. tostring(value)
        if callback then
            task.spawn(function()
                pcall(callback, value)
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    Dropdown.AddOption = function(option)
        table.insert(Dropdown.Options, option)
        BuildOptions()
    end

    Dropdown.RemoveOption = function(option)
        for i, opt in pairs(Dropdown.Options) do
            if opt == option then
                table.remove(Dropdown.Options, i)
                break
            end
        end
        BuildOptions()
    end

    Dropdown.Frame = DropdownFrame
    Elements[Dropdown.Flag] = Dropdown
    table.insert(window.Elements, Dropdown)

    return Dropdown
end

-- Slider Element (with mobile touch support)
function Library:CreateSlider(window, text, min, max, default, decimals, callback, flag)
    local Slider = {
        Type = "Slider",
        Min = min or 0,
        Max = max or 100,
        Value = default or min or 0,
        Decimals = decimals or 0,
        Flag = flag or text .. "_Slider",
        Callback = callback,
        Dragging = false,
    }

    local SliderFrame = CreateInstance("Frame", {
        Name = text,
        Parent = window.Content,
        BackgroundColor3 = Config.Theme.ElementBackground,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, Config.Theme.ElementHeight + 10),
    })
    CreateCorner(SliderFrame)
    CreatePadding(SliderFrame, 4)

    local Label = CreateInstance("TextLabel", {
        Name = "Label",
        Parent = SliderFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -40, 0, 14),
        Font = Config.Theme.Font,
        Text = text,
        TextColor3 = Config.Theme.Text,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local ValueLabel = CreateInstance("TextLabel", {
        Name = "Value",
        Parent = SliderFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 40, 0, 14),
        Position = UDim2.new(1, -40, 0, 0),
        Font = Config.Theme.Font,
        Text = tostring(Slider.Value),
        TextColor3 = Config.Theme.Accent,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Right,
    })

    local SliderBar = CreateInstance("Frame", {
        Name = "Bar",
        Parent = SliderFrame,
        BackgroundColor3 = Config.Theme.TitleBar,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0, 18),
    })
    CreateCorner(SliderBar, UDim.new(1, 0))

    local SliderFill = CreateInstance("Frame", {
        Name = "Fill",
        Parent = SliderBar,
        BackgroundColor3 = Config.Theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 1, 0),
    })
    CreateCorner(SliderFill, UDim.new(1, 0))

    local SliderKnob = CreateInstance("Frame", {
        Name = "Knob",
        Parent = SliderBar,
        BackgroundColor3 = Config.Theme.Text,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 10, 0, 10),
        Position = UDim2.new(0, -5, 0.5, -5),
    })
    CreateCorner(SliderKnob, UDim.new(1, 0))

    local function UpdateSlider(input)
        local pos = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
        local value = Slider.Min + (pos * (Slider.Max - Slider.Min))

        if Slider.Decimals > 0 then
            value = math.floor(value * (10 ^ Slider.Decimals)) / (10 ^ Slider.Decimals)
        else
            value = math.floor(value)
        end

        Slider.Value = value
        ValueLabel.Text = tostring(value)
        SliderFill.Size = UDim2.new(pos, 0, 1, 0)
        SliderKnob.Position = UDim2.new(pos, -5, 0.5, -5)

        if callback then
            task.spawn(function()
                local success, err = pcall(callback, value)
                if not success then
                    warn("Slider callback error: " .. tostring(err))
                end
            end)
        end
    end

    local function SetValue(value)
        value = math.clamp(value, Slider.Min, Slider.Max)
        if Slider.Decimals > 0 then
            value = math.floor(value * (10 ^ Slider.Decimals)) / (10 ^ Slider.Decimals)
        else
            value = math.floor(value)
        end

        Slider.Value = value
        ValueLabel.Text = tostring(value)
        local pos = (value - Slider.Min) / (Slider.Max - Slider.Min)
        SliderFill.Size = UDim2.new(pos, 0, 1, 0)
        SliderKnob.Position = UDim2.new(pos, -5, 0.5, -5)

        if callback then
            task.spawn(function()
                pcall(callback, value)
            end)
        end
        if Config.AutoSave then
            self:SaveConfig()
        end
    end

    -- Initialize
    SetValue(Slider.Value)

    -- Mouse input
    SliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            Slider.Dragging = true
            UpdateSlider(input)
        end
    end)

    -- Touch input for mobile
    SliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            Slider.Dragging = true
            UpdateSlider(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if Slider.Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateSlider(input)
        end
    end)

    -- Touch moved support
    UserInputService.InputChanged:Connect(function(input)
        if Slider.Dragging and input.UserInputType == Enum.UserInputType.Touch then
            UpdateSlider(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Slider.Dragging = false
            if Config.AutoSave then
                self:SaveConfig()
            end
        end
    end)

    Slider.Set = SetValue
    Slider.Frame = SliderFrame
    Elements[Slider.Flag] = Slider
    table.insert(window.Elements, Slider)

