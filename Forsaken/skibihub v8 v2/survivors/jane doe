
-- vars
local jane = require(game:GetService("ReplicatedStorage").Assets.Survivors.JaneDoe.Config)

local minchargeto = 0
local maxchargeto = 0.1

-- setup
local Library = getgenv().Library


Library:Init()

local usingPC = getgenv().usingPC

local main = Library:CreateTabbedWindow("JaneDoe", UDim2.new(0, 50, 0, 50), 250)

local crystal = main:AddTab("Crystal")

Library:CreateSlider(crystal, "Min Charge Time", 0, 10, 0, 0, function(value)
    minchargeto = value
end, "MinIChargeTo")
Library:CreateSlider(crystal, "Max Charge Time", 0.1, 10, 0.1, 0, function(value)
    maxchargeto = value
end, "MaxIChargeTo")

Library:CreateButton(crystal, "Change Charge Time", function()
    jane.Crystal.MinChargeTime = minchargeto
    jane.Crystal.MaxChargeTime = maxchargeto
    Library:Notify("success")
end)

Library:ApplyConfig()
