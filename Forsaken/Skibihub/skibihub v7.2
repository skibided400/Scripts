-- [[ CHANCE ANIMATION DETECTOR ]]
RunService.Heartbeat:Connect(function()
    if not storeHitboxEnabled then return end
    if isCurrentlyBlockingChance then return end -- Prevent spamming the block

    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    local isAiming = false
    -- Check if the player is currently playing one of the Chance Gun animations
    for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
        local idStr = track.Animation and track.Animation.AnimationId:match("%d+")
        if idStr and gunAimIds[idStr] then
            isAiming = true
            break
        end
    end

    if isAiming then
        isCurrentlyBlockingChance = true
        chanceBlockRemote = true -- Triggers the Namecall hook
        
        task.spawn(function()
            local startTime = os.clock()
            local firedGun = false
            
            -- Constantly check for 2 seconds while the block is active
            while os.clock() - startTime < 2 do
                local currentChar = LocalPlayer.Character
                local currentHum = currentChar and currentChar:FindFirstChildOfClass("Humanoid")
                
                if currentHum then
                    for _, track in ipairs(currentHum:GetPlayingAnimationTracks()) do
                        local idStr = track.Animation and track.Animation.AnimationId:match("%d+")
                        if idStr and gunFireIds[idStr] then
                            firedGun = true
                            break
                        end
                    end
                end
                task.wait() -- Checks every frame
            end
            
            -- Turn off the block
            chanceBlockRemote = false
            
            -- ONLY add to the counter if one of the gunFireIds was detected playing
            if firedGun then
                HitboxCounter = HitboxCounter + 1
                if updateStoreHitboxUI then updateStoreHitboxUI() end
            end
            
            -- Small cooldown to wait for the animation track to end properly before allowing another cycle
            task.wait(0.5)
            isCurrentlyBlockingChance = false
        end)
    end
end)



