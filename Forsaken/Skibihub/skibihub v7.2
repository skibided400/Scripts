        if p and p.Parent then p:Destroy() end
    end
    pathingHelperParts = {}
end

local function drawPathingLine(points)
    clearPathingParts()
    for i = 1, #points - 1 do
        local a = points[i]
        local b = points[i + 1]
        local mid = (a + b) / 2
        local dist = (b - a).Magnitude
        if dist < 0.1 then continue end
        local part = Instance.new("Part")
        part.Anchored = true
        part.CanCollide = false
        part.CanQuery = false
        part.CastShadow = false
        part.Material = Enum.Material.Neon
        part.BrickColor = BrickColor.new("Bright yellow")
        part.Transparency = 0.3
        part.Size = Vector3.new(0.2, 0.2, dist)
        part.CFrame = CFrame.new(mid, b)
        part.Parent = workspace
        table.insert(pathingHelperParts, part)
    end
end

local PathfindingService = game:GetService("PathfindingService")

-- State variables to cache the active path and prevent constant jittering/recalculations
local currentPathWaypoints = nil
local lastPathRecalcTime = 0
local RECALC_INTERVAL = 0.4 -- The path remains stable for this duration unless you deviate

local function updatePathingHelper()
    if not isSurvivor() then
        currentPathWaypoints = nil
        clearPathingParts()
        return
    end

    local killer = GetKillerCharacter()
    if not killer then
        currentPathWaypoints = nil
        clearPathingParts()
        return
    end

    local killerRoot = killer:FindFirstChild("HumanoidRootPart")
    if not killerRoot then
        currentPathWaypoints = nil
        clearPathingParts()
        return
    end

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then
        currentPathWaypoints = nil
        clearPathingParts()
        return
    end

    local lpPos = root.Position
    local killerPos = killerRoot.Position
    local now = os.clock()

    -- [[ 1. CONTINUE ACTIVE PATH IF VALID ]]
    if currentPathWaypoints and #currentPathWaypoints > 0 then
        -- Progressively remove waypoints that the LocalPlayer has already reached/passed
        while #currentPathWaypoints > 0 do
            local wpPos = currentPathWaypoints[1]
            -- Check distance purely on the XZ flat plane to prevent disruptions on slopes or stairs
            local distXZ = (Vector3.new(lpPos.X, 0, lpPos.Z) - Vector3.new(wpPos.X, 0, wpPos.Z)).Magnitude
            if distXZ < 5.5 then 
                table.remove(currentPathWaypoints, 1)
            else
                break
            end
        end

        -- Check if the player strayed way off course from the path direction
        if #currentPathWaypoints > 0 then
            local nextWp = currentPathWaypoints[1]
            if (lpPos - nextWp).Magnitude > 18 then
                currentPathWaypoints = nil -- Straying forces a recalculation
            end
        end

        -- If path is still intact and within the cooldown window, continue rendering it smoothly
        if currentPathWaypoints and #currentPathWaypoints >= 2 and (now - lastPathRecalcTime) < RECALC_INTERVAL then
            drawPathingLine(currentPathWaypoints)
            return
        end
    end

    -- [[ 2. PATH RECALCULATION LOOP ]]
    lastPathRecalcTime = now
    local awayDir = (lpPos - killerPos)
    local flatAway = Vector3.new(awayDir.X, 0, awayDir.Z)
    if flatAway.Magnitude < 0.1 then
        flatAway = root.CFrame.LookVector
    end
    flatAway = flatAway.Unit

    local bestPoints = nil
    local angles = {0, 45, -45, 90, -90, 135, -135, 180}

    for _, angleDeg in ipairs(angles) do
        local rad = math.rad(angleDeg)
        local rotated = Vector3.new(
            flatAway.X * math.cos(rad) - flatAway.Z * math.sin(rad),
            0,
            flatAway.X * math.sin(rad) + flatAway.Z * math.cos(rad)
        )

        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {char}
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        
        -- Raycast slightly higher off the floor to bypass low obstacles
        local wallCheck = workspace:Raycast(lpPos + Vector3.new(0, 1.5, 0), rotated * 8, rayParams)
        if wallCheck then continue end

        for _, dist in ipairs({35, 25, 15}) do
            local target = lpPos + rotated * dist

            local path = PathfindingService:CreatePath({
                AgentRadius = 4.5, -- Increased padding size so paths avoid hugging or clipping walls
                AgentHeight = 5,
                AgentCanJump = true, -- Enabled jumping for vertical structural traversal
                AgentCanClimb = false,
                WaypointSpacing = 3.5,
            })

            local ok = pcall(function() path:ComputeAsync(lpPos, target) end)

            if ok and path.Status == Enum.PathStatus.Success then
                local waypoints = path:GetWaypoints()
                if #waypoints >= 2 then
                    local pts = {}
                    for _, wp in ipairs(waypoints) do
                        -- Lift the visual lines up slightly so they float off surfaces cleanly
                        table.insert(pts, wp.Position + Vector3.new(0, 1.5, 0))
                    end
                    bestPoints = pts
                    break
                end
            end
        end

        if bestPoints then break end
    end

    if bestPoints then
        currentPathWaypoints = bestPoints
        drawPathingLine(currentPathWaypoints)
    else
        currentPathWaypoints = nil
        clearPathingParts()
    end
end

local function stopPathingHelper()
    if pathingHelperConnection then
        pathingHelperConnection:Disconnect()
        pathingHelperConnection = nil
    end
    currentPathWaypoints = nil -- Clear cache on toggle-off
    clearPathingParts()
end


