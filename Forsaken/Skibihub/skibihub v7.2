local function buildChanceArgs()
    local x = 0.08853239566087723
    local y = -0.000001093038576982508
    local z = 0.996073305606842
    local ok, created = pcall(function() return vector.create(x, y, z) end)
    if ok and created ~= nil then
        return { LocalPlayer.Name .. "ChanceFireShot", { created } }
    end
    return { LocalPlayer.Name .. "ChanceFireShot", { Vector3.new(x, y, z) } }
end

