local function isPlayingInvisAnim(humanoid)
    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        if track.IsPlaying then
            local id = track.Animation and track.Animation.AnimationId:match("%d+")
            if id and INVIS_ANIM_IDS[id] then
                return true
            end
        end
    end
    return false
end

local crouchAnimPool = {}
local crouchAnimLoaded = nil
local poolIndex = 0 -- round-robin pointer

local function stopCrouchHideAnim()
    for _, track in ipairs(crouchAnimPool) do
        if track and track.IsPlaying then
            track:Stop()
        end
    end
end

local function startCrouchHideAnim(humanoid)
    if not crouchAnimLoaded then
        crouchAnimLoaded = Instance.new("Animation")
        crouchAnimLoaded.AnimationId = HIDE_ANIM_ID
    end

    -- Build pool up to 60 first
    if #crouchAnimPool < 60 then
        local track = humanoid:LoadAnimation(crouchAnimLoaded)
        track.Priority = Enum.AnimationPriority.Action4
        track.Looped = false
        track:AdjustSpeed(0.0000000000000000000001)
        track:Play()
        table.insert(crouchAnimPool, track)
        return
    end

    -- Round-robin: recycle oldest track instead of waiting for it to stop
    poolIndex = (poolIndex % #crouchAnimPool) + 1
    local track = crouchAnimPool[poolIndex]
    if track then
        track:Stop()
        track:Play()
    end
end
local lp = LocalPlayer

local function GetCharacterAt(mode: string, wallCheck: boolean)
	local camera = workspace.CurrentCamera
	local lpChar = lp.Character
	if not lpChar then return nil end

	local lpRoot = lpChar:FindFirstChild("HumanoidRootPart")
	if not lpRoot then return nil end

	local bestChar = nil
	local bestScore = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if player == lp then continue end

		local char = player.Character
		if not char then continue end

		local root = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not root or not hum or hum.Health <= 0 then continue end

		local score

		if mode == "closestH" then
			-- Score by world-space distance from lp's root
			score = (root.Position - lpRoot.Position).Magnitude

		elseif mode == "closestC" then
			-- Score by how close the target is to the center of the camera's screen
			local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)
			if not onScreen then continue end

			local viewportSize = camera.ViewportSize
			local center = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
			local screenPoint = Vector2.new(screenPos.X, screenPos.Y)
			score = (screenPoint - center).Magnitude
		else
			warn("GetCharacterAt: unknown mode '" .. tostring(mode) .. "'")
			return nil
		end

		-- Wall check: cast a ray from lp's root toward the target.
		-- If it hits something before reaching the target, skip them.
		if wallCheck then
			local origin = lpRoot.Position
			local direction = (root.Position - origin)
			local distance = direction.Magnitude
			local unitDir = direction / distance

			local rayParams = RaycastParams.new()
			rayParams.FilterDescendantsInstances = {lpChar, char}
			rayParams.FilterType = Enum.RaycastFilterType.Exclude

			local result = workspace:Raycast(origin, unitDir * distance, rayParams)

			-- If the ray hit something, there's a wall in the way
			if result then continue end
		end

		if score < bestScore then
			bestScore = score
			bestChar = char
		end
	end

	return bestChar
end

