-- Fire Remote logic when pressing the button
-- Fire Remote logic when pressing the button
storeHitboxBtn.Activated:Connect(function()
    if HitboxCounter > 0 then
        local args = buildChanceArgs()
        
        -- Wrap the firing logic into a function so we can reuse it cleanly
        local function fireRemoteLogic()
            pcall(function()
                game:GetService("ReplicatedStorage").Modules.Network.Network.RemoteEvent:FireServer(unpack(args))
            end)
            
            -- Deduct 1 from counter and update UI
            HitboxCounter = HitboxCounter - 1
            if updateStoreHitboxUI then updateStoreHitboxUI() end
        end

        -- [[ NEW: TP First Logic ]]
        if tpFirstEnabled then
            task.spawn(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then 
                    fireRemoteLogic() -- Fallback if your character is dead/missing
                    return 
                end

                -- Save position before teleporting
                local originalCFrame = hrp.CFrame
                task.wait(0.01)

                local startTime = os.clock()
                local firedRemote = false
                local tpConnection

                -- Step 1: Constantly TP 3 studs behind killer for 1 second
                tpConnection = RunService.Heartbeat:Connect(function()
                    local elapsed = os.clock() - startTime
                    if elapsed >= 1 then
                        tpConnection:Disconnect()
                        return
                    end

                    local cChar = LocalPlayer.Character
                    local cHrp = cChar and cChar:FindFirstChild("HumanoidRootPart")
                    local killer = GetKillerCharacter()
                    local killerHrp = killer and killer:FindFirstChild("HumanoidRootPart")

                    if cHrp and killerHrp then
                        -- Positive Z pushes your position backward relative to the killer's face direction
                        cHrp.CFrame = killerHrp.CFrame * CFrame.new(0, 0, 3)
                    end

                    -- Fire the remote event exactly 0.4 seconds into the TP phase
                    if elapsed >= 0.4 and not firedRemote then
                        firedRemote = true
                        fireRemoteLogic()
                    end
                end)

                task.wait(0.7) -- Wait out the 1-second phase

                -- Step 2: Constantly TP back to original position for 0.2 seconds
                local returnStartTime = os.clock()
                local returnConnection
                returnConnection = RunService.Heartbeat:Connect(function()
                    if os.clock() - returnStartTime >= 0.2 then
                        returnConnection:Disconnect()
                        return
                    end
                    local cChar = LocalPlayer.Character
                    local cHrp = cChar and cChar:FindFirstChild("HumanoidRootPart")
                    if cHrp then
                        cHrp.CFrame = originalCFrame
                    end
                end)

                task.wait(0.2) -- Wait out the 0.2-second phase
            end)

        -- If "Aim First" is turned on, run the aiming sequence instead
        elseif gunAimFirstEnabled then
            local killer = GetKillerCharacter()
            if killer then
                AimAt(killer, 0.7, "Character", false)
                AimAt(killer, 0.7, "Camera", false)
                task.delay(0.4, fireRemoteLogic)
            else
                fireRemoteLogic()
            end
        else
            -- If no specific custom movement toggle is on, fire instantly
            fireRemoteLogic()
        end
    end
end)

