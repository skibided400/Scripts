-- [[ HITBOX IMITATE MODE ]]
local function spawnImitateHitbox(soundDescendant)
    local sourcePart = nil
    local okSource = pcall(function()
        local p = soundDescendant.Parent and soundDescendant.Parent.Parent
        if p and p:IsA("BasePart") then sourcePart = p end
    end)
    if not okSource or not sourcePart then
        pcall(function()
            local p = soundDescendant.Parent
            if p and p:IsA("BasePart") then sourcePart = p end
        end)
    end
    if not sourcePart then return end

    local timeout = os.clock()
    while soundDescendant.TimeLength == 0 and (os.clock() - timeout) < 0.5 do
        task.wait()
    end
    local duration = soundDescendant.TimeLength > 0 and soundDescendant.TimeLength or 1.5
    local activeDuration = duration * (hitboxDurationPercentage / 100)

    local BASE_X, BASE_Y, BASE_Z = hitboxBaseSize.X, hitboxBaseSize.Y, hitboxBaseSize.Z
    local FORWARD_OFFSET = 1.5

    -- Main hitbox part
    local hitboxPart = Instance.new("Part")
    hitboxPart.Name = "AutoBlockImitateHitbox"
    hitboxPart.Anchored = true
    hitboxPart.CanCollide = false
    hitboxPart.Transparency = 0.04
    hitboxPart.BrickColor = BrickColor.new("Bright blue")
    hitboxPart.Material = Enum.Material.Neon
    hitboxPart.Size = Vector3.new(BASE_X, BASE_Y, BASE_Z)
    hitboxPart.CastShadow = false
    hitboxPart.Parent = workspace

    -- Table to track circle clone parts
    local circleParts = {}

    local fired = false
    local lastPosition = sourcePart.Position
    local lastCFrame = sourcePart.CFrame
    local startTime = os.clock()

    local function checkOverlap(part, hrpPos)
        local halfSize = part.Size / 2
        local localLP = part.CFrame:PointToObjectSpace(hrpPos)
        return math.abs(localLP.X) <= halfSize.X + 1.5
            and math.abs(localLP.Y) <= halfSize.Y + 1.5
            and math.abs(localLP.Z) <= halfSize.Z + 1.5
    end

    local function cleanupAll()
        hitboxPart:Destroy()
        for _, p in ipairs(circleParts) do
            if p and p.Parent then p:Destroy() end
        end
        circleParts = {}
    end

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if fired
            or not autoBlockEnabled
            or autoBlockMode ~= 2
            or (os.clock() - startTime) >= activeDuration
            or not soundDescendant
            or not soundDescendant.Parent
        then
            cleanupAll()
            if conn then conn:Disconnect() end
            return
        end

        local sourceCFrame
        local okCF = pcall(function() sourceCFrame = sourcePart.CFrame end)
        if not okCF or not sourceCFrame then return end

        local forwardPos = sourceCFrame.Position + sourceCFrame.LookVector * FORWARD_OFFSET
        local newCFrame = CFrame.new(forwardPos) * (sourceCFrame - sourceCFrame.Position)

        
        -- ARV
        local sizeX, sizeZ = BASE_X, BASE_Z
        local offsetX, offsetZ = 0, 0

        -- Pre-calculate RR rotDelta so ARV can check if RR is active
        local prevLook = lastCFrame.LookVector
        local currLook = sourceCFrame.LookVector
        lastCFrame = sourceCFrame
        local prevLookXZ = Vector3.new(prevLook.X, 0, prevLook.Z)
        local currLookXZ = Vector3.new(currLook.X, 0, currLook.Z)
        local cross = prevLookXZ:Cross(currLookXZ)
        local rotDelta = cross.Y -- positive = right, negative = left

        local rrIsActive = rotationResizeEnabled and math.abs(rotDelta) > 0.0001

        if autoResizeEnabled then
            local currentPos = sourcePart.Position
            local vel = currentPos - lastPosition
            lastPosition = currentPos
            local localVel = sourceCFrame:VectorToObjectSpace(vel)

            local extraX = localVel.X * autoResizeSensitivity * 10
            local extraZ = localVel.Z * autoResizeSensitivity * 10

            local arvIsDoingSomething = math.abs(extraX) > 0.001 or math.abs(extraZ) > 0.001

            -- Skip ARV if "ignore ARV" is on and RR is active
            if not (arvIgnoreWhenRR and rrIsActive) then
                sizeX = math.clamp(BASE_X + math.abs(extraX), BASE_X, BASE_X * 6)
                sizeZ = math.clamp(BASE_Z + math.abs(extraZ), BASE_Z, BASE_Z * 6)
                offsetX = extraX / 2
                offsetZ = extraZ / 2
            end

            -- Store whether ARV is doing something for RR to check
            _G._arvDoingSomething = arvIsDoingSomething
        else
            _G._arvDoingSomething = false
        end

        if rotationResizeEnabled then
            -- Skip RR if "ignore RR" is on and ARV is doing something
            if rrIgnoreWhenARV and _G._arvDoingSomething then
                -- do nothing for RR this frame
            elseif true then
            if rrShape == 1 then
                -- SIDE mode (original behaviour)
                local extraX = rotDelta * rotationResizeSensitivity * 120

                sizeX = math.clamp(sizeX + math.abs(extraX), BASE_X, BASE_X * 6)
                offsetX = offsetX + (-extraX / 2)

            elseif rrShape == 2 then
                -- CIRCLE mode
                -- Destroy previous circle clones each frame so they refresh
                for _, p in ipairs(circleParts) do
                    if p and p.Parent then p:Destroy() end
                end
                circleParts = {}

                -- Arc degrees driven by rotation speed and sensitivity
                local arcDegrees = math.abs(rotDelta) * rotationResizeSensitivity * 3000
                arcDegrees = math.clamp(arcDegrees, 0, 360)

                if arcDegrees >= 1 then
                    -- Step every ~15 degrees so we don't spam too many parts
                    local stepDeg = 15
                    local steps = math.floor(arcDegrees / stepDeg)

                    -- Rotation direction: rotDelta positive = sweeping right (negative Y axis rotation)
                    local dirSign = rotDelta >= 0 and 1 or -1

                    for i = 1, steps do
                        local angleDeg = i * stepDeg * dirSign
                        local angleRad = math.rad(angleDeg)

                        -- Rotate the forward offset around Y axis of source
                        local rotatedCFrame = sourceCFrame * CFrame.Angles(0, angleRad, 0)
                        local cloneForwardPos = rotatedCFrame.Position + rotatedCFrame.LookVector * FORWARD_OFFSET
                        local cloneCFrame = CFrame.new(cloneForwardPos) * (rotatedCFrame - rotatedCFrame.Position)

                        local clone = Instance.new("Part")
                        clone.Name = "AutoBlockImitateHitbox_Circle"
                        clone.Anchored = true
                        clone.CanCollide = false
                        clone.Transparency = 0.35
                        clone.BrickColor = BrickColor.new("Bright blue")
                        clone.Material = Enum.Material.Neon
                        clone.Size = Vector3.new(sizeX, BASE_Y, sizeZ)
                        clone.CastShadow = false
                        clone.CFrame = cloneCFrame * CFrame.new(offsetX, 0, offsetZ)
                        clone.Parent = workspace

                        table.insert(circleParts, clone)
                    end
                end
            end
            end -- closes the elseif true
        end
        

        -- Update main hitbox
        hitboxPart.Size = Vector3.new(sizeX, BASE_Y, sizeZ)
        hitboxPart.CFrame = newCFrame * CFrame.new(offsetX, 0, offsetZ)

        -- Overlap check on main part and all circle clones
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local hrpPos = hrp.Position
            local hit = checkOverlap(hitboxPart, hrpPos)
            if not hit then
                for _, p in ipairs(circleParts) do
                    if p and p.Parent and checkOverlap(p, hrpPos) then
                        hit = true
                        break
                    end
                end
            end
            if hit then
                fired = true
                fireRemote("Block")
                cleanupAll()
                if conn then conn:Disconnect() end
            end
        end
    end)
end

-- TWO TIME FUNCTIONS
local function fireBackstabEffect()
    if isSpectator() then return end
    if not isTwoTime() then return end
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local startTime = os.clock()
    local conn

    if backstabBe == 1 then
        -- Blatant: constantly stay behind killer
        conn = RunService.RenderStepped:Connect(function()
            if (os.clock() - startTime) >= backstabDuration then
                conn:Disconnect()
                return
            end

            local killer = GetKillerCharacter()
            if not killer then return end
            local tRoot = killer:FindFirstChild("HumanoidRootPart")
            if not tRoot then return end
            pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", tRoot) end)

            local behindPos = tRoot.CFrame * CFrame.new(0, 0, backstabTPDistance)
            root.CFrame = CFrame.new(behindPos.Position, tRoot.Position)
        end)
    elseif backstabBe == 2 then
        -- Legit: mirror killer's look direction
        conn = RunService.RenderStepped:Connect(function()
            if (os.clock() - startTime) >= backstabDuration then
                conn:Disconnect()
                return
            end

            local killer = GetKillerCharacter()
            if not killer then return end
            local tRoot = killer:FindFirstChild("HumanoidRootPart")
            if not tRoot then return end
            pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", tRoot) end)

            local killerLook = tRoot.CFrame.LookVector
            root.CFrame = CFrame.new(root.Position, root.Position + killerLook)
        end)
    elseif backstabBe == 3 then
        -- Semi legit (1): like Blatant but lerps instead of teleporting
        conn = RunService.RenderStepped:Connect(function()
            if (os.clock() - startTime) >= backstabDuration then
                conn:Disconnect()
                return
            end

            local killer = GetKillerCharacter()
            if not killer then return end
            local tRoot = killer:FindFirstChild("HumanoidRootPart")
            if not tRoot then return end
            pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", tRoot) end)

            local targetCFrame = tRoot.CFrame * CFrame.new(0, 0, backstabTPDistance)
            local targetPos = CFrame.new(targetCFrame.Position, tRoot.Position)
            root.CFrame = root.CFrame:Lerp(targetPos, 0.6)
        end)

    elseif backstabBe == 4 then
        -- Semi legit (2): look at killer's facing direction once, blockRemote = true, then TP, then TP back
        local killer = GetKillerCharacter()
        if not killer then return end
        local tRoot = killer:FindFirstChild("HumanoidRootPart")
        if not tRoot then return end

        local originalCFrame = root.CFrame

        -- Face the direction the killer is looking (like Legit mode), once
        local killerLook = tRoot.CFrame.LookVector
        root.CFrame = CFrame.new(root.Position, root.Position + killerLook)
        root.CFrame = CFrame.new(root.Position, root.Position + killerLook)

        blockRemote = true

        conn = RunService.RenderStepped:Connect(function()
            if (os.clock() - startTime) >= backstabDuration then
                conn:Disconnect()
                blockRemote = false
                pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", root) end)
                root.CFrame = originalCFrame
                pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", nil) end)
                return
            end

            local tCFrame = tRoot.CFrame
            if tCFrame then
                local behindPos = tCFrame * CFrame.new(0, 0, backstabTPDistance)
                root.CFrame = CFrame.new(behindPos.Position, tRoot.Position)
            end
        end)
    end

    pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", nil) end)
end

