local function monitorHighlight(highlight)
    if monitoredHighlights[highlight] then return end
    monitoredHighlights[highlight] = true

    local hasTriggered = false

    spawn(function()
        while true do
            if not highlight or not highlight.Parent then
                monitoredHighlights[highlight] = nil
                break
            end

            local adornee = highlight.Adornee
            if isDescendantOfCharacter(adornee) then
                if not hasTriggered then
                    triggerAction()
                    hasTriggered = true
                end
            else
                hasTriggered = false
            end

            task.wait(0.1)
        end
    end)
end

local function startAutoTrick()
    if autoTrickConnection then
        autoTrickConnection:Disconnect()
    end

    -- Clear any existing monitored highlights
    monitoredHighlights = {}

    -- Watch for new Highlights
    autoTrickConnection = game.DescendantAdded:Connect(function(descendant)
        if descendant:IsA("Highlight") and descendant:GetFullName() == "ReplicatedStorage.Assets.Survivors.Veeronica.Behavior.Highlight" then
            monitorHighlight(descendant)
        end
    end)

    -- Check existing Highlights
    for _, descendant in ipairs(game:GetDescendants()) do
        if descendant:IsA("Highlight") and descendant:GetFullName() == "ReplicatedStorage.Assets.Survivors.Veeronica.Behavior.Highlight" then
            monitorHighlight(descendant)
        end
    end
end

local function stopAutoTrick()
    if autoTrickConnection then
        autoTrickConnection:Disconnect()
        autoTrickConnection = nil
    end
    monitoredHighlights = {}
end

