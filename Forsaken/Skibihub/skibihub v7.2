-- SWING DETECTOR
task.spawn(function()
    local playersFolder = workspace:WaitForChild("Players", 15)
    if not playersFolder then return end
    local killersFolder = playersFolder:WaitForChild("Killers", 15)
    if not killersFolder then return end
    
    killersFolder.DescendantAdded:Connect(function(descendant)

        if descendant:IsA("Sound") then
            -- Safely extract only digits from the SoundId string
            local idNum = tonumber(string.match(descendant.SoundId, "%d+"))
            
            if idNum and targetSoundIds[idNum] then
                if autoBackstabEnabled and autoBackstabMode == 2 and isTwoTime() then
                    twotimeparry = true
                end

                if not autoBlockEnabled then return end
                task.wait(autoBlockDelay)
                -- =========================================
                -- MODE 2: Hitbox (Imitate)
                -- =========================================

                if autoBlockMode == 2 then
                    task.spawn(function()
                        spawnImitateHitbox(descendant)
                    end)
                    return
                end


                -- =========================================
                -- MODE 1: Normal (original behaviour)
                -- =========================================
                -- Determine if we need to poll constantly (if Hitbox Dragg OR Constant Facing Check are active)
                local needsPolling = (distanceCheckEnabled and blockHitboxDraggEnabled) or facingCheckCCEnabled
                
                if needsPolling then
                    -- Constant polling implementation
                    task.spawn(function()
                        -- Wait briefly for TimeLength to replicate if it loads as 0
                        local timeout = os.clock()
                        while descendant.TimeLength == 0 and (os.clock() - timeout) < 0.5 do
                            task.wait()
                        end
                        
                        while autoBlockEnabled and descendant and descendant.Parent do
                            -- Stop tracking if the sound fully stopped playing and reset
                            if not descendant.IsPlaying and descendant.TimePosition == 0 then
                                break
                            end
                            
                            local currentTime = descendant.TimePosition
                            local duration = descendant.TimeLength > 0 and descendant.TimeLength or 1.5
                            
                            -- Evaluate dynamic cutoffs
                            local bhdExpired = false
                            if distanceCheckEnabled and blockHitboxDraggEnabled then
                                if currentTime >= (duration * (stopCheckPercentage / 100)) then
                                    bhdExpired = true
                                end
                            end
                            
                            local fcCcExpired = false
                            if facingCheckCCEnabled then
                                if currentTime >= (duration * (stopCheckPercentageFC / 100)) then
                                    fcCcExpired = true
                                end
                            end
                            
                            -- Break loop if all requested polling timelines have run out
                            local loop1Active = (distanceCheckEnabled and blockHitboxDraggEnabled)
                            local loop2Active = facingCheckCCEnabled
                            if (loop1Active and bhdExpired or not loop1Active) and (loop2Active and fcCcExpired or not loop2Active) then
                                break
                            end
                            
                            local success, soundOrigin = pcall(function() return descendant.Parent.Parent.CollisionHitbox.Position end)
                            if success and soundOrigin and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                local lpPosition = LocalPlayer.Character.HumanoidRootPart.Position
                                
                                -- 1. Distance validation
                                local distancePassed = true
                                if distanceCheckEnabled then
                                    local distance = (soundOrigin - lpPosition).Magnitude
                                    if distance > distanceStuds then
                                        distancePassed = false
                                    end
                                end
                                
                                -- 2. Facing validation
                                local facingPassed = true
                                if facingCheckEnabled or facingCheckCCEnabled then
                                    local successCFrame, parentCFrame = pcall(function() return descendant.Parent.CFrame end)
                                    if successCFrame and parentCFrame then
                                        local lookVec = parentCFrame.LookVector
                                        local diff = (lpPosition - soundOrigin)
                                        if diff.Magnitude > 0 then
                                            local toLP = diff.Unit
                                            local dot = lookVec:Dot(toLP)
                                            local angle = math.acos(math.clamp(dot, -1, 1)) * (180 / math.pi)
                                            if angle > facingDegrees then
                                                facingPassed = false
                                            end
                                        end
                                    else
                                        facingPassed = false
                                    end
                                end
                                
                                -- Verify if the current valid statuses aren't blocked by a time expiry
                                local allowedByBhd = not (loop1Active and bhdExpired)
                                local allowedByFc = not (loop2Active and fcCcExpired)
                                
                                if distancePassed and facingPassed and allowedByBhd and allowedByFc then
                                    fireRemote("Block")
                                    break -- Exit constant loop once block successfully registers
                                end
                            end
                            task.wait()
                        end
                    end)
                else
                    -- Standard single check execution
                    local success, soundOrigin = pcall(function() return descendant.Parent.Position end)
                    if success and soundOrigin and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local lpPosition = LocalPlayer.Character.HumanoidRootPart.Position
                        
                        -- 1. Distance validation
                        local distancePassed = true
                        if distanceCheckEnabled then
                            local distance = (soundOrigin - lpPosition).Magnitude
                            if distance > distanceStuds then
                                distancePassed = false
                            end
                        end
                        
                        -- 2. Facing validation
                        local facingPassed = true
                        if facingCheckEnabled then
                            local successCFrame, parentCFrame = pcall(function() return descendant.Parent.CFrame end)
                            if successCFrame and parentCFrame then
                                local lookVec = parentCFrame.LookVector
                                local diff = (lpPosition - soundOrigin)
                                if diff.Magnitude > 0 then
                                    local toLP = diff.Unit
                                    local dot = lookVec:Dot(toLP)
                                    local angle = math.acos(math.clamp(dot, -1, 1)) * (180 / math.pi)
                                    if angle > facingDegrees then
                                        facingPassed = false
                                    end
                                end
                            else
                                facingPassed = false
                            end
                        end
                        
                        if distancePassed and facingPassed then
                            fireRemote("Block")
                        end
                    end
                end
            end
        end
    end)
end)

