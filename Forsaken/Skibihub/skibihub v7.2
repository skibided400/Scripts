local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    -- Your original block logic
    if blockRemote and method == "FireServer" and self.Name == "UnreliableRemoteEvent" then
        return nil
    end

    -- [[ NEW: Block ChanceFireShot Remote ]]
    if chanceBlockRemote and method == "FireServer" and self.Name == "RemoteEvent" then
        if args[1] == LocalPlayer.Name .. "ChanceFireShot" then
            return nil
        end
    end

    return oldNamecall(self, ...)
end)


-- TWO TIME
RunService.Heartbeat:Connect(function()
    if not autoBackstabEnabled then return end
    if not isTwoTime() then return end
    if autoBackstabMode == 2 then return end

    local killer = GetKillerCharacter()
    if not killer then return end
    local tRoot = killer:FindFirstChild("HumanoidRootPart")
    if not tRoot then return end

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local lpPos = root.Position
    local killerCFrame = tRoot.CFrame

    local inRange = false

    if backstabDetectWhere == 1 then
        -- Behind: check if lp is within range behind the killer
        local behindPos = (killerCFrame * CFrame.new(0, 0, backstabDetectionRange)).Position
        local dist = (lpPos - behindPos).Magnitude
        inRange = dist <= backstabDetectionRange
    elseif backstabDetectWhere == 2 then
        -- Around: check if lp is within range of killer at all
        local dist = (lpPos - tRoot.Position).Magnitude
        inRange = dist <= backstabDetectionRange
    end

    if inRange then
        fireRemote("Dagger", true)
        tryBackstab = true
        task.wait(2)
        tryBackstab = false
    end
end)

