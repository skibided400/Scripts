local function fireRemote(name, other)
    local prefix = {0x03, 0x05, 0x00, 0x00, 0x00}
    local seem = other or false
   
    if seem == true then
        prefix = {0x03, 0x06, 0x00, 0x00, 0x00}
    end

    local totalLen = #prefix + #name
    local buf = buffer.create(totalLen)

    for i, byte in ipairs(prefix) do
        buffer.writeu8(buf, i - 1, byte)
    end

    for i = 1, #name do
        buffer.writeu8(buf, #prefix + i - 1, string.byte(name, i))
    end

    local args = {
        "UseActorAbility",
        { buf }
    }

    local replicatedStorage = game:GetService("ReplicatedStorage")
    local modules = replicatedStorage:FindFirstChild("Modules")
    local network1 = modules and modules:FindFirstChild("Network")
    local network2 = network1 and network1:FindFirstChild("Network")
    local remoteEvent = network2 and network2:FindFirstChild("RemoteEvent")

    if remoteEvent then
        remoteEvent:FireServer(unpack(args))
    end
end


